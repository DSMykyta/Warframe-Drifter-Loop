# game/dialogues/arthur/arthur_eleanor_secret.rpy
# Артур про свою сестру-близнюка Елеонор

init python:
    DIALOGUE_ENTRIES.append({
        "id": "arthur_eleanor_secret",
        "who": "Артур",
        "conditions": {
            "flag_true": ["arthur_leadership_burden_done"],
            "flag_false": ["arthur_eleanor_secret_done"],
            "chemistry_min": ("Артур", 75),
            "rank_min": 3,
        },
        "priority": 55,
        "chance": 100,
        "label": "arthur_eleanor_secret",
    })

label arthur_eleanor_secret:
    show arthur at char_center
    $ store.talked_today.add("Артур")

    ar "Ти знаєш, що ми з Елеонор — близнюки?"
    $ advance_time(5)

    mc "Чув натяки. Але ніхто не розповідав деталей."
    $ advance_time(5)

    ar "Бо деталі... складні."
    $ advance_time(5)

    ar "Ми народилися з різницею у вісім хвилин. Вона — старша. І вона ніколи не дає мені це забути."
    $ advance_time(5)

    mc "Типова старша сестра?"
    $ advance_time(5)

    ar "Ні. Нетипова. Елеонор... вона відчуває речі. Людей. Думки."
    $ advance_time(5)

    ar "Не читає в прямому сенсі. Але вона дивиться на тебе і знає, що ти відчуваєш. Що приховуєш. Від чого тікаєш."
    $ advance_time(5)

    mc "А ти?"
    $ advance_time(5)

    ar "А я — ні. Я — звичайний. Без жодних здібностей. Просто хлопець з мечем і планом."
    $ advance_time(5)

    ar "Уяви: ти зростаєш поруч з людиною, яка завжди знає більше за тебе. Завжди бачить глибше. Завжди на крок попереду."
    $ advance_time(5)

    mc "Це мало бути... важко."
    $ advance_time(5)

    ar "Важко — не те слово. Я все дитинство намагався довести, що я теж чогось вартий. Пішов у ICR — вона ні. Взяв на себе лідерство — вона не хотіла."
    $ advance_time(5)

    ar "Я весь час біжу, щоб бути на рівні з людиною, яка навіть не змагається."
    $ advance_time(5)

    menu:
        "Ви ж все одно разом. Це щось значить":
            $ advance_time(5)
            mc "Але вона тут. З тобою. Це щось значить, ні?"

            ar "Значить. Вона сказала — «я йду, бо без мене ти загинеш на другому місяці». Типова Елеонор."
            $ advance_time(5)

            ar "Але... так. Мені легше, коли вона поруч. Навіть якщо це ніколи не скажу їй в обличчя."
            $ advance_time(5)
            $ add_chemistry("Артур", 4)

        "Може, вона теж тебе потребує?":
            $ advance_time(5)
            mc "А ти не думав, що вона теж тебе потребує? Що її здібності — це не все?"

            ar "...Вона одного разу сказала, що я — єдина людина, біля якої їй тихо. Що з іншими вона весь час «чує» шум."
            $ advance_time(5)

            ar "Я не знаю, чи це означає, що вона мене потребує. Але мені хочеться так думати."
            $ advance_time(5)
            $ add_chemistry("Артур", 4)

        "Ти не мусиш з нею змагатися":
            $ advance_time(5)
            mc "Артуре, ти лідер Гексу. Ти ведеш за собою людей. Це не менше за те, що вміє вона."

            ar "Розумом я це знаю. Але десь всередині досі живе хлопчик, який біг за сестрою і не міг наздогнати."
            $ advance_time(5)

            ar "Можливо, вже час перестати бігти."
            $ advance_time(5)
            $ add_chemistry("Артур", 4)

    ar "Не розповідай їй, що я це казав. Вона і так все знає, але... нехай вдає, що ні."
    $ advance_time(5)

    $ store.seen_dialogues.add("arthur_eleanor_secret")
    $ set_flag("arthur_eleanor_secret_done")
    $ add_insight("arthur_eleanor_twins", "Артур і Елеонор — близнюки. Вона має емпатичні здібності, він — ні. Це завжди було джерелом його невпевненості.")
    $ add_insight("eleanor_empathy", "Елеонор відчуває емоції інших. Біля Артура їй «тихо» — він єдиний, хто не створює шуму.")

    hide arthur
    return
