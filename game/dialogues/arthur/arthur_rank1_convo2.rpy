# game/dialogues/arthur/arthur_rank1_convo2.rpy
# ArthurRank1Convo2 — Артур питає про гурт On-lyne. Легка, невимушена розмова.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "arthur_rank1_convo2",
        "who": "Артур",
        "conditions": {
            "flag_false": ["arthur_rank1_convo2_done"],
            "chemistry_min": ("Артур", 5),
        },
        "priority": 45,
        "chance": 100,
        "label": "arthur_rank1_convo2",
    })

label arthur_rank1_convo2:
    show arthur at char_center
    $ store.talked_today.add("Артур")
    $ dialogue_begin()

    ar "Слухай, тебе ж дратує On-lyne?"

    ar "Ця група грає скрізь. У кожному барі, кожному магазині. Я вже не витримую."

    menu:
        "Так, жахлива музика":
            mc "Повністю згоден. Одна й та сама мелодія по колу, ніби застрягли в петлі."

            ar "Нарешті хтось із глуздом. Елеонор каже, що я просто старий буркун."

            $ add_chemistry("Артур", 2)

            ar "Але ж це об'єктивно погана музика. Три акорди і крик замість вокалу."

            mc "Може, це і є секрет популярності. Чим простіше, тим ширша аудиторія."

            ar "Хм. Ненавиджу, що це має сенс."

            $ add_chemistry("Артур", 2)

        "Мені подобається On-lyne":
            mc "Ну... вони не такі вже й погані. Є пара непоганих пісень."

            ar "...Серйозно?"

            ar "Гаразд. Не буду сперечатись. Але мої вуха з тобою не згодні."

        "Я не знаю хто це":
            mc "Я навіть не знаю, хто такі On-lyne."

            ar "Щасливець. Бережи цю невинність."

            $ add_chemistry("Артур", 2)

    menu:
        "А яку музику ти слухаєш?":
            mc "Ну а що тобі до вподоби? Класика? Важкий метал?"

            ar "Тиша. Тиша — найкраща музика після довгого дня."

            ar "...Але якщо серйозно, старі записи. Ще до Порожнечі. Щось справжнє."

            $ add_chemistry("Артур", 2)
            $ add_insight("arthur_music", "Артуру подобається стара музика. On-lyne його дратує.")

        "Може, ти просто старієш":
            mc "Знаєш, це класична ознака старіння. Нова музика дратує..."

            ar "Обережно. Я ще не настільки старий, щоб це терпіти."

            ar "Хоча... можливо, трохи. Не кажи нікому."

            $ add_chemistry("Артур", 2)

    $ dialogue_end()
    $ store.seen_dialogues.add("arthur_rank1_convo2")
    $ set_flag("arthur_rank1_convo2_done")

    hide arthur
    return
