# game/dialogues/arthur/arthur_intro_bro.rpy
# ═══════════════════════════════════════════════════
# БОНУСНА ГІЛКА: "Хай, бро" — підстава від Квінсі
# ═══════════════════════════════════════════════════
# Окремий бонусний вхід в інтро Артура.
# Видимий ТІЛЬКИ якщо quincy_told_bro = True.
# Після гілки — jump в arthur_intro_missions (основний файл).
# Артур стає грубим і сухим до кінця розмови.

init python:
    BONUS_OPTIONS.append({
        "id": "arthur_bro_greeting",
        "who": "Артур",
        "text": "Хай, бро.",
        "label": "arthur_intro_bro",
        "conditions": {
            "flag_true": ["quincy_told_bro"],
            "flag_false": ["arthur_intro_done"],
        },
        "once": True,
    })


label arthur_intro_bro:

    mc "Хай, бро."

    ar "..."

    ar "Як ти мене назвав?"

    mc "Ну... бро. Квінсі сказав що ти—"

    ar "Квінсі."

    ar "Звісно."

    ar "Послухай мене уважно."

    ar "Я тобі не «бро». Не «братан». Не «чувак»."

    ar "Я — Артур. Командир цієї групи."

    ar "Ти можеш звати мене Артур. Або «сер». Або нічого."

    ar "Це зрозуміло?"

    menu:
        "Зрозуміло. Вибач.":
            mc "Зрозуміло. Вибач."

            ar "Не вибачайся переді мною. Вибачайся перед собою за те що послухав Квінсі."

            $ add_chemistry("Артур", -2)

        "[Мовчати.]":
            mc "..."

            ar "Мовчання — теж відповідь. Прийнятна."

    $ set_flag("arthur_bro_incident")
    # mark_bonus_used — автоматично в location_loop при показі меню
    $ add_insight("quincy_prank_bro", "Квінсі підставив мене з Артуром. Артур НЕ любить «бро». Запам'ятати.")

    ar "А тепер до справи."

    # Повертаємось в основний діалог — але Артур вже грубий
    jump arthur_intro_missions
