# game/dialogues/arthur/arthur_icr_trauma.rpy
# Глибока травма — що сталося в ICR

init python:
    DIALOGUE_ENTRIES.append({
        "id": "arthur_icr_trauma",
        "who": "Артур",
        "conditions": {
            "flag_true": ["arthur_skana_story_told", "arthur_eleanor_secret_done"],
            "flag_false": ["arthur_icr_trauma_done"],
            "chemistry_min": ("Артур", 80),
            "rank_min": 4,
        },
        "priority": 50,
        "cooldown_tag": "heavy_lore",
        "chance": 100,
        "label": "arthur_icr_trauma",
    })

label arthur_icr_trauma:
    show arthur at char_center
    $ store.talked_today.add("Артур")

    ar "Сядь. Сьогодні... я хочу розповісти все. Про ICR. Про те, що насправді сталося."
    $ advance_time(5)

    mc "Я слухаю. Не поспішай."
    $ advance_time(5)

    ar "Я вступив у ICR, коли мені було вісімнадцять. Вірив у місію. «Захист порядку, стабільність, безпека». Гарні слова."
    $ advance_time(5)

    ar "Перший рік був ідеальним. Тренування, операції, чітка структура. Мені подобалось. Я нарешті відчував, що я — на своєму місці."
    $ advance_time(5)

    ar "Потім почались «спеціальні завдання». Зачистки. Перехоплення. Ліквідації."
    $ advance_time(5)

    ar "Нам казали — це повстанці, терористи, загрози. Я вірив. Бо альтернатива — визнати, що я працюю на монстрів."
    $ advance_time(5)

    mc "Коли ти зрозумів?"
    $ advance_time(5)

    ar "Коли загинув Мартін — це був перший удар. Але я залишився. Сказав собі: «зміню систему зсередини»."
    $ advance_time(5)

    ar "Потім була операція «Жнива». Три селища. Офіційна версія — зачистка від контрабандистів. Реальність — ICR хотіла контролювати водний ресурс."
    $ advance_time(5)

    ar "Я бачив тіла. Жінки, діти, старі. Це були не контрабандисти. Це були люди, які просто жили не в тому місці."
    $ advance_time(5)

    ar "Я відмовився продовжувати. Мене оголосили зрадником. Дали двадцять чотири години, перш ніж почнуть полювання."
    $ advance_time(5)

    mc "Як ти вижив?"
    $ advance_time(5)

    ar "Елеонор. Вона відчула, що щось не так. З'явилася за мною за шість годин до дедлайну. Не питала нічого. Просто сказала «їдемо»."
    $ advance_time(5)

    ar "Ми тікали два тижні. Змінювали маршрути, ховалися. Вона відчувала патрулі до того, як ми їх бачили."
    $ advance_time(5)

    ar "Потім знайшли Гекс. Або Гекс знайшов нас. Летті підібрала нас напівмертвих біля Порт-Веро."
    $ advance_time(5)

    ar "Я приніс з собою Скану Мартіна, навички ICR і купу кошмарів. Це все, що залишилося."
    $ advance_time(5)

    menu:
        "ICR заплатить за це":
            $ advance_time(5)
            mc "Одного дня вони заплатять за все, що зробили."

            ar "Може. А може — ні. Я більше не живу задля помсти. Я живу, щоб ті, хто зі мною, були в безпеці."
            $ advance_time(5)
            $ chemistry["Артур"] += 3

        "Ти зробив правильний вибір":
            $ advance_time(5)
            mc "Ти відмовився. Це робить тебе кращою людиною, ніж усі вони разом."

            ar "Кращою? Ні. Я п'ять років виконував накази, перш ніж знайшов межу. П'ять років."
            $ advance_time(5)

            ar "Але так. Я зробив вибір. І це — єдине, за що я себе не ненавиджу."
            $ advance_time(5)
            $ chemistry["Артур"] += 4

        "Ти не один у цьому. Більше ніколи":
            $ advance_time(5)
            mc "Ти більше не один, Артуре. Ті два тижні тікання — це минуле. Зараз у тебе є ми."

            ar "...Знаю. І від цього одночасно легше і страшніше. Бо тепер є що втрачати."
            $ advance_time(5)
            $ chemistry["Артур"] += 5

    ar "Дякую, що вислухав. Тепер ти знаєш все. І я сподіваюсь, це не змінить того, як ти на мене дивишся."
    $ advance_time(5)

    $ store.seen_dialogues.add("arthur_icr_trauma")
    $ set_flag("arthur_icr_trauma_done")
    $ add_insight("arthur_icr_full", "ICR — воєнізована організація, що прикривалася захистом порядку. Операція «Жнива» — масове вбивство за ресурси. Артур відмовився і став зрадником.")
    $ add_insight("arthur_eleanor_rescue", "Елеонор врятувала Артура з ICR. Відчула біду і приїхала за шість годин до початку полювання.")
    $ add_insight("hex_origin_lettie", "Летті підібрала Артура й Елеонор напівмертвих біля Порт-Веро. Так почався Гекс.")

    hide arthur
    return
