# game/dialogues/arthur/arthur_intro.rpy
# ═══════════════════════════════════════════════════
# АРТУР — ІНТРО: Місії + пояснення правил + підстава "бро"
# ═══════════════════════════════════════════════════
# Перша розмова з Артуром. Пояснює місії і правила.
# Бонус: якщо Квінсі сказав називати "бро" — опція в меню.
# "Бро" → мінус хімія, грубість, Артур зрізає далі коротко.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "arthur_intro",
        "who": "Артур",
        "conditions": {
            "flag_false": ["arthur_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Привіт.", "arthur_intro_normal"),
            ("Хай, бро.", "arthur_intro_bro", "quincy_told_bro"),
        ],
    })

    # Бонусна опція від Квінсі — вклинюється в titles
    # "Хай, бро" видно тільки якщо quincy_told_bro = True
    # Реалізація: в titles є обидва варіанти, але в screen
    # другий показується тільки при наявності флагу.
    #
    # !!! УВАГА: поточна система titles не підтримує conditions
    # !!! на окремі titles. Тому "бро" реалізовано як окремий
    # !!! label що перевіряє флаг зсередини. Якщо флагу нема —
    # !!! перенаправляє на нормальний вхід.


label arthur_intro_bro:
    mc "Хай, бро."

    ar "..."

    ar "Бро?"

    ar "Хто тебе цьому навчив?"

    menu:
        "Квінсі сказав що ти це любиш.":
            mc "Квінсі сказав що ти це любиш."

            ar "Квінсі. Звісно."

            ar "Значить так, Марті. Я тобі не «бро». Я тобі не «братан». І не «чувак»."

            ar "Я — Артур. Командир цієї групи. Це зрозуміло?"

            mc "Зрозуміло."

            ar "Добре. А Квінсі я поговорю."

            $ add_chemistry("Артур", -2)
            $ set_flag("arthur_bro_incident")
            $ add_insight("quincy_prank_bro", "Квінсі підставив мене з Артуром. Артур НЕ любить коли його називають «бро».")

        "[Мовчати.]":
            mc "..."

            ar "Хтось тебе підставив. Давай забудемо і почнемо знову."

            $ set_flag("arthur_bro_incident")

    jump arthur_intro_missions


label arthur_intro_normal:

    mc "Привіт."

    ar "Привіт, Марті."

    ar "Ти вчасно. Мені треба тобі дещо пояснити."

    jump arthur_intro_missions


label arthur_intro_missions:

    ar "Місії. Це головне, чим ми тут займаємось."

    ar "Щодня генеруються завдання. Різного рівня складності."

    ar "Рівень один — розвідка. Рівень шість — ти або вони."

    ar "Нагорода залежить від рівня. Гроші, репутація."

    ar "Репутація — це довіра Гексу до тебе. Чим більше — тим більше можливостей."

    if store.flags.get("arthur_bro_incident"):
        # Після "бро" — коротко і сухо, без пояснень
        ar "Місії в гаражі. Напарник — один з нас. Не халтур."

        ar "Все."

    else:
        # Нормальний розгорнутий варіант
        ar "Для місій потрібно йти в гараж. Там дошка завдань."

        ar "Кожна місія має напарника — когось з Гексу. Працюєте разом."

        menu:
            "А якщо я не хочу йти на місію?":
                mc "А якщо я вирішу пропустити?"

                ar "Один-два дні — нічого. Три — починають питання."

                ar "П'ять — всі починають сумніватись чи ти взагалі тут потрібен."

                ar "Я не загрожую. Я попереджаю."

                $ add_chemistry("Артур", 2)

            "Зрозумів. Місії — пріоритет.":
                mc "Зрозумів. Місії — пріоритет."

                ar "Саме так."

                $ add_chemistry("Артур", 2)

            "А якщо халтурити?":
                mc "А якщо... ну... не дуже старатись?"

                ar "Тоді ти підставляєш напарника. А напарник — це хтось із моїх людей."

                ar "І я це сприйму особисто."

                mc "Зрозумів."

                $ add_chemistry("Артур", 4)
                $ add_insight("arthur_protects_team", "Артур захищає свою команду. Халтура на місіях — особиста образа для нього.")

    ar "Ще питання?"

    menu:
        "Де саме гараж?":
            mc "Де цей гараж?"

            ar "Через комп'ютерний клуб. Побачиш вивіску."

        "Ні, все зрозуміло.":
            mc "Ні. Все зрозуміло."

            ar "Добре. Не розчарую."

            mc "Не розчарую."

            ar "Побачимо."

            $ add_chemistry("Артур", 2)

    $ store.seen_dialogues.add("arthur_intro")
    $ set_flag("arthur_intro_done")
    $ add_journal_entry("Артур пояснив систему місій. Гараж, напарники, репутація. Халтура — не варіант.", "event")
    $ add_insight("arthur_leader", "Артур — лідер Гексу. Місії в гаражі. Не терпить халтури.")
    $ add_insight("missions_garage", "Місії — в гаражі через комп'ютерний клуб. Щодня нові завдання.")

    return
