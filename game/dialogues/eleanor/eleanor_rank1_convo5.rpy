# game/dialogues/eleanor/eleanor_rank1_convo5.rpy
# Елеонор — Ранг 1, Розмова 5: Після смерті

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_rank1_convo5",
        "who": "Елеонор",
        "conditions": {
            "flag_false": ["eleanor_rank1_convo5_done"],
            "chemistry_min": ("Елеонор", 22),
        },
        "priority": 45,
        "chance": 100,
        "label": "eleanor_rank1_convo5",
    })

label eleanor_rank1_convo5:
    show eleanor at char_center
    $ store.talked_today.add("Елеонор")
    $ dialogue_begin()

    el "Дрифтер. Сядь. Мені потрібна розмова, яку ніхто інший не витримає."

    mc "Звучить обнадійливо."

    el "Що відбувається після смерті?"

    mc "...Ти серйозно?"

    el "Абсолютно. Ти — єдиний у Голлванії, хто знає більше одного варіанту відповіді. Твій всесвіт мав технології, що торкались цього питання."

    el "Мене не цікавить віра. Мене цікавлять факти. Що ти бачив?"

    menu:
        "Цефалони — розум, записаний у машину.":
            jump eleanor_r1c5_cephalon

        "Орокін переносили свідомість у нові тіла.":
            jump eleanor_r1c5_orokin

        "Переміщення Тенно — ти живеш через інших.":
            jump eleanor_r1c5_transference

label eleanor_r1c5_cephalon:
    mc "Цефалони. Штучний інтелект, створений із людської свідомості. Тебе сканують — і копія живе вічно у цифровому просторі."

    el "Копія. Не ти — а копія."

    mc "Технічно — так. Але Цефалони мають спогади, характер, навіть примхи оригіналу."

    el "Але оригінал мертвий."

    mc "Так."

    el "Отже, це не безсмертя. Це плагіат. Хтось інший живе з твоїми спогадами і думає, що він — це ти."

    el "Жахливо. І водночас... спокусливо."

    menu:
        "Ти б хотіла стати Цефалоном?":
            mc "Ти б хотіла? Зберегти свій розум — навіть якщо це буде копія?"

            el "Частина мене — так. Та частина, що боїться забути, як складати речення."

            el "Але інша частина знає: Елеонор без тіла, без подразнення від мокрих шкарпеток, без головного болю вранці — це не Елеонор. Це архів."

            $ add_chemistry("Елеонор", 2)

        "Деякі Цефалони шкодують, що погодились.":
            mc "Деякі Цефалони шкодують. Вони пам'ятають, що мали тіло — і не можуть змиритись із його відсутністю."

            el "Фантомний біль свідомості. Звісно. Як телепат, позбавлений чужих думок — у порожній кімнаті."

            el "Ні. Це не для мене."

            $ add_chemistry("Елеонор", 2)

    jump eleanor_r1c5_identity

label eleanor_r1c5_orokin:
    mc "Орокін мали Безперервність. Коли тіло старіло — вони переносили свідомість у нове. Зазвичай — у чуже."

    el "У чуже? Тобто вони крали тіла?"

    mc "Так. Молоді, здорові тіла. Попередній власник... зникав."

    el "Безсмертя ціною чужого існування. Це не технологія — це паразитизм із кращим маркетингом."

    mc "Орокін не бачили в цьому проблеми. Вони вважали себе вищими істотами."

    el "Звісно вважали. Кожен тиран вважає себе необхідністю."

    menu:
        "Ти б скористалась такою можливістю?":
            mc "Якщо чесно — якби тобі запропонували нове тіло, без Техроту... ти б відмовилась?"

            el "...Не зараз. Запитай через рік, коли Техрот дійде до кісток."

            el "Жартую. Мабуть."

            $ add_chemistry("Елеонор", 2)

        "Тенно повалили Орокін саме через це.":
            mc "Тенно повстали проти Орокін. Частково — через Безперервність. Це було занадто."

            el "Революція проти безсмертних. І ви перемогли. Це... вселяє повагу."

            $ add_chemistry("Елеонор", 2)

    jump eleanor_r1c5_identity

label eleanor_r1c5_transference:
    mc "Переміщення. Тенно з'єднують свідомість із варфреймом. Ти відчуваєш його тіло як своє. Рухаєшся, б'єшся, вмираєш — але твоє справжнє тіло в безпеці."

    el "Ти живеш через маску. Через аватар."

    mc "Не зовсім. Варфрейм — не маска. Він... частина тебе. Ти відчуваєш його біль, його сили."

    el "Це те, що я роблю з Нікс. Але навпаки."

    mc "Навпаки?"

    el "Я контролюю чужі розуми ззовні. Ти входиш у чуже тіло зсередини. Ми — дзеркальні відображення."

    mc "Ніколи не думав про це так."

    el "Тому я тут. Щоб думати про речі, про які інші не думають."

    menu:
        "А ти не боїшся загубитись у Нікс?":
            mc "А ти не боїшся, що одного дня Нікс поглине тебе? Що ти забудеш, де закінчується фрейм і починаєшся ти?"

            el "Щодня. Кожного разу, коли надягаю Нікс — є мить, коли я не знаю, чиї думки мої. Це проходить. Але мить — страшна."

            $ add_chemistry("Елеонор", 4)
            $ add_insight("eleanor_nyx_fear", "Кожне переміщення в Нікс має мить, коли Елеонор не розрізняє свої думки від чужих.")

        "Дзеркальні відображення. Мені подобається ця думка.":
            mc "Дзеркальні відображення. Мені подобається."

            el "Не звикай. Я рідко кажу речі, які подобаються людям."

            $ add_chemistry("Елеонор", 2)

    jump eleanor_r1c5_identity

label eleanor_r1c5_identity:

    el "Ось що мене справді турбує. Не механізм — а питання тотожності."

    el "Якщо мою свідомість перенести — у Цефалон, у нове тіло, в Нікс назавжди — це буду я? Чи хтось інший з моїми спогадами?"

    mc "Це питання, на яке ніхто не має відповіді. Навіть Орокін уникали його."

    el "Вони уникали, бо відповідь могла зруйнувати їхню індустрію безсмертя."

    el "А я не уникаю. Я хочу знати. Навіть якщо відповідь — «ні, це не ти»."

    el "Знаєш, що найгірше?"

    mc "Що?"

    el "Ніхто не запитує, як я себе почуваю. Летті перевіряє тіло. Артур перевіряє бойову готовність. Квінсі перевіряє наявність спірту в аптечці."

    el "Але ніхто — ніхто — не сідає навпроти й не каже: «Елеонор, як ти?»"

    el "Крім тебе. Зараз."

    menu:
        "Як ти, Елеонор?":
            mc "Тоді скажу це просто. Як ти, Елеонор?"

            el "..."

            el "Я боюсь. Я втомилась. Я не знаю, скільки часу в мене залишилось."

            el "Але зараз, у цю хвилину, мені краще. Тому що хтось запитав."

            el "Дякую. Це... більше, ніж ти думаєш."

            $ add_chemistry("Елеонор", 4)
            $ set_flag("eleanor_bereaved")

        "Ти не мусиш бути сильною весь час.":
            mc "Ти не мусиш тримати обличчя весь час. Тут безпечно."

            el "Безпечно. Яке дивне слово для місця, де все повільно вмирає."

            el "Але... може, ти маєш рацію. Може, безпека — це не місце. Це людина."

            el "Не цитуй мене. Я цього не казала."

            $ add_chemistry("Елеонор", 4)
            $ set_flag("eleanor_bereaved")

    $ dialogue_end()
    $ store.seen_dialogues.add("eleanor_rank1_convo5")
    $ set_flag("eleanor_rank1_convo5_done")
    $ add_insight("eleanor_loneliness", "Ніхто в команді не запитує Елеонор, як вона себе почуває. Летті стежить за тілом, Артур — за боєготовністю. Емоційно вона самотня.")

    hide eleanor
    return
