# game/dialogues/eleanor/eleanor_rank1_convo3.rpy
# Елеонор — Ранг 1, Розмова 3: Безодня

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_rank1_convo3",
        "who": "Елеонор",
        "conditions": {
            "flag_true": ["eleanor_intro_done", "eleanor_rank1_convo2_done"],
            "flag_false": ["eleanor_rank1_convo3_done"],
            "rank_min": 1,
        },
        "priority": 45,
        "chance": 100,
        "label": "eleanor_rank1_convo3",
    })

label eleanor_rank1_convo3:
    show eleanor at char_center
    $ store.talked_today.add("Елеонор")

    el "Після нашого останнього сеансу я не спала дві ночі."
    $ advance_time(3)

    mc "Через те, що побачила?"
    $ advance_time(3)

    el "Через те, що не побачила. Був шар у твоїх спогадах — щось під усім іншим. Темне. Безмежне. Живе."
    $ advance_time(3)

    el "Порожнеча. Бездна. Ти називаєш це Войд."
    $ advance_time(3)

    mc "Ти відчула Войд?"
    $ advance_time(3)

    el "Краєчком. Як доторкнутись до полум'я й відсмикнути руку. Але навіть цього краєчка вистачило, щоб зрозуміти — це не просто енергія."
    $ advance_time(3)

    el "Що це для тебе, Дрифтер? Що таке Войд?"
    $ advance_time(3)

    menu:
        "Войд — джерело моїх сил. Без нього я — ніхто.":
            jump eleanor_r1c3_power

        "Войд зруйнував моїх батьків. Це не подарунок — це прокляття.":
            jump eleanor_r1c3_parents

        "Войд був моїм домом. Єдиним місцем, де я почувався в безпеці.":
            jump eleanor_r1c3_home

label eleanor_r1c3_power:
    mc "Войд — це те, що робить мене Тенно. Переміщення, контроль над варфреймами, все."
    $ advance_time(3)

    mc "Забери його — і я просто підліток зі зламаною долею."
    $ advance_time(3)

    el "Ти кажеш це так буденно. Ніби носити в собі фрагмент... чогось такого — нормально."
    $ advance_time(3)

    mc "Для мене — нормально. Я нічого іншого не знаю."
    $ advance_time(3)

    el "Я намагалась класифікувати те, що відчула. Не вийшло. Це не псі-енергія. Не біотика. Не технологія."
    $ advance_time(3)

    el "Якби я була релігійною людиною — а я не є — я б сказала, що це щось... божественне."
    $ advance_time(3)

    menu:
        "Може, й божественне. Тенно ніколи точно не знали.":
            mc "Може, й так. Орокін поклонялися Войду. Тенно просто ним користувалися. Істина десь посередині."
            $ advance_time(3)

            el "Між поклонінням і утилітарністю. Яке людське місце для істини."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 4)

        "Не божественне. Просто інше. Дуже, дуже інше.":
            mc "Не надавай йому більше значення, ніж є. Войд — це сила. Небезпечна сила."
            $ advance_time(3)

            el "Небезпечна сила, яка обрала тебе. Або яку обрали для тебе. Ти не бачиш у цьому іронії?"
            $ advance_time(3)

            $ add_chemistry("Елеонор", 2)

    $ set_flag("eleanor_void_love")
    $ add_insight("eleanor_void_divine", "Елеонор вважає Войд чимось, що виходить за межі відомих категорій. Можливо, чимось божественним.")

    jump eleanor_r1c3_end

label eleanor_r1c3_parents:
    mc "Мої батьки... вони були на кораблі Зарімана. Коли він провалився у Войд — вони змінились."
    $ advance_time(3)

    el "Змінились як?"
    $ advance_time(3)

    mc "Збожеволіли. Войд дав дітям сили. А дорослих — зламав. Вони стали небезпечними."
    $ advance_time(3)

    el "І тобі довелось..."
    $ advance_time(3)

    mc "Так."
    $ advance_time(3)

    el "Ти був дитиною."
    $ advance_time(3)

    mc "Так."
    $ advance_time(3)

    el "..."
    $ advance_time(3)

    el "Вибач. Мені потрібна хвилинка."
    $ advance_time(3)

    el "Я чула багато жахливих історій. Але ця... Ти носиш у собі силу, що знищила твою родину. І все одно використовуєш її."
    $ advance_time(3)

    menu:
        "Бо альтернатива — здатися. А я не здаюсь.":
            mc "Альтернатива — лягти й померти. Я обрав не це."
            $ advance_time(3)

            el "Ти обрав жити з інструментом свого горя. Це або мужність, або мазохізм. Я вирішу пізніше."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 4)

        "Іноді я ненавиджу кожну мить цієї сили.":
            mc "Іноді я ненавиджу Войд. Усім серцем. А потім він рятує мені життя — і я знову мовчу."
            $ advance_time(3)

            el "Складні стосунки з тим, що тебе визначає. Я це розумію більше, ніж хотіла б."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 2)

    $ set_flag("eleanor_drifter_parents")
    $ add_insight("eleanor_knows_parents", "Елеонор знає про батьків Дрифтера — що Войд зламав їх, і що Дрифтер був дитиною, коли все сталося.")

    jump eleanor_r1c3_end

label eleanor_r1c3_home:
    mc "Войд був моїм домом. У Дувірі, на кораблі — скрізь, де Войд присутній, я відчував... спокій."
    $ advance_time(3)

    el "Спокій? У тому, що я відчула як бездонну темряву?"
    $ advance_time(3)

    mc "Для тебе — темрява. Для мене — тиша. Жодних чужих голосів, жодних очікувань. Просто... простір."
    $ advance_time(3)

    el "Ти щойно описав мою мрію. Я щодня шукаю тишу — і не знаходжу. А ти народився в ній."
    $ advance_time(3)

    mc "Я за це заплатив. Самотністю."
    $ advance_time(3)

    el "Самотність і тиша — близькі сусіди, так?"
    $ advance_time(3)

    menu:
        "Так. Іноді не відрізниш одне від іншого.":
            mc "Так. Іноді не знаєш — ти на спокої чи просто один."
            $ advance_time(3)

            el "Запишу це. Якщо дозволиш — використаю як епіграф, коли нарешті напишу мемуари."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 2)

        "Але самотність закінчилась. Я тут.":
            mc "Але самотність — у минулому. Тепер у мене є команда. Є ви."
            $ advance_time(3)

            el "«Є ви.» Боже, Дрифтер. Ти щойно зробив так, що в мене заболіло серце. Не фізично. Це гірше."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 4)

    $ set_flag("eleanor_void_love")
    $ add_insight("eleanor_void_home", "Дрифтер описав Войд як тишу й дім. Для Елеонор це ідеальна протилежність її телепатичного хаосу.")

    jump eleanor_r1c3_end

label eleanor_r1c3_end:

    el "Дрифтер. Ця розмова була... важчою, ніж я планувала."
    $ advance_time(3)

    el "Я звикла збирати інформацію. Класифікувати, аналізувати, архівувати."
    $ advance_time(3)

    el "Але те, що ти мені довірив — це не інформація. Це щось більше."
    $ advance_time(3)

    mc "Щось більше?"
    $ advance_time(3)

    el "Ти довірив мені біль. А біль — це не дані. Це привілей."
    $ advance_time(3)

    el "Я це ціную. Навіть якщо не вмію це показати."
    $ advance_time(3)

    $ store.seen_dialogues.add("eleanor_rank1_convo3")
    $ set_flag("eleanor_rank1_convo3_done")

    hide eleanor
    return
