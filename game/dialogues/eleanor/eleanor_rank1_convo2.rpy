# game/dialogues/eleanor/eleanor_rank1_convo2.rpy
# Елеонор — Ранг 1, Розмова 2: Покажи мені спогади

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_rank1_convo2",
        "who": "Елеонор",
        "conditions": {
            "flag_false": ["eleanor_rank1_convo2_done"],
            "chemistry_min": ("Елеонор", 4),
        },
        "priority": 45,
        "chance": 100,
        "label": "eleanor_rank1_convo2",
    })

label eleanor_rank1_convo2:
    show eleanor at char_center
    $ store.talked_today.add("Елеонор")
    $ dialogue_begin()

    el "Дрифтер. Маю до тебе... делікатне прохання."

    mc "Делікатне? Від тебе? Це вже інтригує."

    el "Не лести собі. Я прошу це з наукових міркувань."

    el "Ти прийшов з іншого всесвіту. Системи Походження. Я читала звіти, але звіти — це пересохлі кістки без м'яса."

    el "Хочу побачити твої спогади. Безпосередньо. Через телепатичний контакт."

    menu:
        "Що саме ти хочеш побачити?":
            mc "Що саме ти хочеш побачити? У мене багато спогадів — не всі приємні."

            el "Обирай ти. Покажи те, що вважаєш за потрібне. Мене цікавить не конкретний факт — а масштаб."

        "А якщо я не хочу, щоб хтось лазив у мене в голові?":
            mc "Слухай, я не великий фанат того, щоб хтось копирсався в моїх думках."

            el "Я не копирсатимусь. Ти покажеш — я побачу. Різниця між обшуком і екскурсією."

            el "Крім того, ти Дрифтер. Якщо тобі не сподобається — просто зачини двері. У тебе стіни міцніші за будь-якого телепата."

            $ add_chemistry("Елеонор", 2)

    el "Отож. Що ти хочеш мені показати?"

    menu:
        "Королівство Дувірі — театр без глядачів.":
            jump eleanor_r1c2_duviri

        "Колонії Системи Походження — де я виріс.":
            jump eleanor_r1c2_origin

        "Ентраті — родина, що живе серед мертвих.":
            jump eleanor_r1c2_entrati

        "Лотос — ту, що вела нас.":
            jump eleanor_r1c2_lotus

label eleanor_r1c2_duviri:
    mc "Дувірі. Це місце, де емоції правлять реальністю. Буквально."

    el "Зачекай. Я бачу... яскраве небо, що змінює колір з настроєм його короля? Дракон, зшитий із вітру?"

    el "Це неможливо. Реальність не може бути залежною від психічного стану однієї людини."

    mc "Може. Там — може."

    el "Як Нікс-оператор я маніпулюю свідомістю. Але там свідомість маніпулює матерією..."

    el "Це інверсія всього, що я знаю. І це... вражає."

    $ set_flag("eleanor_saw_duviri")
    $ add_chemistry("Елеонор", 2)
    $ add_insight("eleanor_duviri_reaction", "Елеонор вражена Дувірі — місцем, де свідомість керує матерією. Для неї це інверсія її власних здібностей.")

    jump eleanor_r1c2_reflection

label eleanor_r1c2_origin:
    mc "Колонії. Реле. Сітуси. Місця, де людство тримається за виживання обома руками."

    el "Я бачу... станції, що обертаються навколо мертвих планет. Базари, де торгують зброєю та надією в рівних пропорціях."

    el "Люди. Скрізь люди. Вони живуть, навіть коли все навколо каже їм вмерти."

    mc "Звучить знайомо, чи не так?"

    el "Надто знайомо. Але там масштаб... мільйони, мільярди. І вони тримаються."

    el "Якщо людство здатне вижити там — можливо, ми не такі приречені, як мені здається о третій ночі."

    $ set_flag("eleanor_saw_origin")
    $ add_chemistry("Елеонор", 4)
    $ add_insight("eleanor_origin_hope", "Побачивши масштаб Системи Походження, Елеонор знайшла крихту надії: якщо людство виживає там, можливо, вижве й тут.")

    jump eleanor_r1c2_reflection

label eleanor_r1c2_entrati:
    mc "Родина Ентраті. Вони жили поруч із Зараженими — буквально — і не здалися."

    el "Зараження... як наш Техрот?"

    mc "Гірше. Набагато гірше. Воно перетворює тіло повністю. Але Ентраті знайшли спосіб існувати поруч."

    el "Я бачу їхні обличчя. Наполовину людські, наполовину... щось інше. І вони все одно сваряться за обіднім столом."

    el "Це одночасно жахливо і... дивовижно. Навіть коли тіло зраджує — сім'я залишається."

    mc "Вони б тебе зрозуміли."

    el "...Можливо. Можливо."

    $ set_flag("eleanor_saw_entrati")
    $ add_chemistry("Елеонор", 4)
    $ add_insight("eleanor_entrati_kinship", "Елеонор побачила в Ентраті дзеркало свого стану — тіло, що змінюється, але людяність, що залишається.")

    jump eleanor_r1c2_reflection

label eleanor_r1c2_lotus:
    mc "Лотос. Вона вела Тенно. Була нашим голосом у навушниках, нашим компасом."

    el "Я бачу... жінку в шоломі. Спокійний голос. Абсолютна впевненість."

    el "Але під шоломом — розлом. Вона не знала, хто вона насправді. Чи любить вас — чи виконує програму."

    mc "Ти бачиш більше, ніж я показував."

    el "Вибач. Коли образ сильний — я ковзаю глибше за дозволене. Професійна вада."

    el "Але ця жінка... вона зробила вибір. Обрала вас. Навіть ціною себе."

    el "Це рідкість. У будь-якому всесвіті."

    $ set_flag("eleanor_saw_lotus")
    $ add_chemistry("Елеонор", 2)
    $ add_insight("eleanor_lotus_reading", "Елеонор при телепатичному контакті «ковзнула» глибше за дозволене. Побачила внутрішній конфлікт Лотос.")

    jump eleanor_r1c2_reflection

label eleanor_r1c2_reflection:

    el "Дрифтер."

    mc "Так?"

    el "Дякую. Я не очікувала побачити... стільки."

    el "Ми тут, у Голлванії, думаємо, що наш шматок реальності — єдиний. Що Техрот — найстрашніше, що може статись."

    el "А ти приніс із собою докази, що всесвіт значно більший за наші страхи."

    menu:
        "Більший — але не безпечніший.":
            mc "Більший — але не безпечніший. Там своїх кошмарів вистачає."

            el "Так, але кошмар з контекстом — менш жахливий, ніж кошмар у темряві. Тепер я бачу контекст."

        "Завжди радий показати.":
            mc "Завжди радий показати. Тільки попередь наступного разу — я підготую щось гарніше."

            el "Гарніше мені не потрібно. Мені потрібне справжнє. І ти дав саме це."

            $ add_chemistry("Елеонор", 2)

    $ dialogue_end()
    $ store.seen_dialogues.add("eleanor_rank1_convo2")
    $ set_flag("eleanor_rank1_convo2_done")

    hide eleanor
    return
