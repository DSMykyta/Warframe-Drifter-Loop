# game/dialogues/eleanor/eleanor_rank1_convo1.rpy
# Елеонор — Ранг 1, Розмова 1: Контроль і мистецтво

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_rank1_convo1",
        "who": "Елеонор",
        "conditions": {
            "flag_true": ["eleanor_intro_done"],
            "flag_false": ["eleanor_rank1_convo1_done"],
            "rank_min": 1,
        },
        "priority": 50,
        "chance": 100,
        "label": "eleanor_rank1_convo1",
    })

label eleanor_rank1_convo1:
    show eleanor at char_center
    $ store.talked_today.add("Елеонор")

    el "Ти помічав, що я ніколи не говорю з тобою подумки?"
    $ advance_time(3)

    mc "Тепер, коли ти це згадала — так. Чому?"
    $ advance_time(3)

    el "Бо слова — це мистецтво. Телепатія — це зліпок емоцій, брудний пакет відчуттів без структури."
    $ advance_time(3)

    el "А речення... речення можна скласти. Відшліфувати. Приховати одне, підкреслити інше."
    $ advance_time(3)

    mc "Тобто ти обираєш текст, бо він дає тобі контроль?"
    $ advance_time(3)

    el "Контроль — таке потворне слово. Скажімо... редагування. Я редагую себе перед тим, як показати світові."
    $ advance_time(3)

    menu:
        "Звучить як журналістська звичка.":
            jump eleanor_r1c1_journalism

        "А що, якщо хтось хоче побачити нередаговану версію?":
            jump eleanor_r1c1_unedited

        "Ти боїшся, що люди побачать справжню тебе?":
            jump eleanor_r1c1_fear

label eleanor_r1c1_journalism:
    mc "Це звучить як професійна деформація. Ти була журналісткою?"
    $ advance_time(3)

    el "О. Хтось зробив домашнє завдання."
    $ advance_time(3)

    el "Так. До Голлванії. До Техроту. До всього цього безладу я писала для «Глобал Нарративу». Довгі розслідування, аналітика."
    $ advance_time(3)

    el "Найкраща робота у світі. Ти береш хаос реальності й вкладаєш його в абзаци. Причина, наслідок, висновок."
    $ advance_time(3)

    mc "Сумуєш за цим?"
    $ advance_time(3)

    el "Щодня. Але зараз у мене інший набір інструментів. Замість ручки — Нікс. Замість слів — псі-імпульси."
    $ advance_time(3)

    el "Хоча, якщо чесно, принцип той самий. Знайди правду, сформулюй, доведи до аудиторії."
    $ advance_time(3)

    $ add_chemistry("Елеонор", 4)
    $ add_insight("eleanor_journalist", "Елеонор працювала журналісткою в «Глобал Нарративі» до подій у Голлванії. Писала розслідування.")

    jump eleanor_r1c1_sanity

label eleanor_r1c1_unedited:
    mc "А якщо хтось хоче побачити чернетку? Без правок?"
    $ advance_time(3)

    el "Тоді цей хтось або дуже сміливий, або дуже нерозумний."
    $ advance_time(3)

    el "Нередагована Елеонор — це потік чужих думок, тривога, сарказм як захисний механізм і... небажання бути вразливою."
    $ advance_time(3)

    mc "Це звучить як більшість людей, яких я знаю."
    $ advance_time(3)

    el "...Тебе важко вразити, правда?"
    $ advance_time(3)

    $ add_chemistry("Елеонор", 2)

    jump eleanor_r1c1_sanity

label eleanor_r1c1_fear:
    mc "Ти боїшся, що справжня ти комусь не сподобається?"
    $ advance_time(3)

    el "Яка пряма атака. Без маневрів."
    $ advance_time(3)

    el "Ні. Я не боюсь. Я просто знаю з досвіду, що відвертість — це зброя, яку люди використовують проти тебе."
    $ advance_time(3)

    el "Тому я тримаю свою при собі."
    $ advance_time(3)

    mc "Зрозуміло. Але знай — я не збираюсь нічого використовувати."
    $ advance_time(3)

    el "Поки що — я тобі вірю. Поки що."
    $ advance_time(3)

    $ add_chemistry("Елеонор", 2)

    jump eleanor_r1c1_sanity

label eleanor_r1c1_sanity:

    el "Знаєш, що найгірше в телепатії? Ти не можеш вимкнути чужі голоси. Вони завжди там. Фоновий шум."
    $ advance_time(3)

    el "Тексти, нотатки, структуровані думки — це мій спосіб створити тишу. Маленький острівець порядку в океані чужого хаосу."
    $ advance_time(3)

    menu:
        "Кожен має свій спосіб не зійти з розуму.":
            mc "Кожен має свій спосіб не зійти з розуму. Я тебе розумію."
            $ advance_time(3)

            el "«Кожен має свій спосіб залишатись при розумі.» Саме так. Дякую, що не кажеш, що це дивно."
            $ advance_time(3)

            $ add_chemistry("Елеонор", 2)

        "А як щодо Техроту? Він впливає на твої здібності?":
            mc "Слухай, а Техрот... він якось впливає на твою телепатію? Стає гірше?"
            $ advance_time(3)

            el "О, яке чарівне питання. Давай я відповім метафорою: уяви, що твоє радіо зламане і ловить сто станцій одночасно. А тепер додай статику."
            $ advance_time(3)

            el "Але не хвилюйся. Я тримаюсь."
            $ advance_time(3)

            el "Наступне питання?"
            $ advance_time(3)

            mc "Зрозумів. Тема закрита."
            $ advance_time(3)

            $ add_insight("eleanor_techrot_telepathy", "Техрот погіршує телепатію Елеонор — додає «статику» до і так перевантаженого сприйняття.")

    el "Приємна бесіда, Дрифтер. Можеш повторити колись."
    $ advance_time(3)

    $ store.seen_dialogues.add("eleanor_rank1_convo1")
    $ set_flag("eleanor_rank1_convo1_done")

    hide eleanor
    return
