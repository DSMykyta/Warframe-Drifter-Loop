# game/dialogues/eleanor/eleanor_intro.rpy
# ═══════════════════════════════════════════════════
# ЕЛЕОНОР — ІНТРО: Телепатія + хто вона + Техрот
# ═══════════════════════════════════════════════════
# Елеонор говорить інакше. Частина розмови — телепатична
# (хвильовий текст по центру екрану замість say window).
# Це її фішка — вона перемикається між текстом і думками.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_intro",
        "who": "Елеонор",
        "conditions": {
            "flag_false": ["eleanor_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Привіт, Елеонор.", "eleanor_intro_main"),
        ],
    })


label eleanor_intro_main:

    mc "Привіт, Елеонор."

    el "Привіт."

    el "Ти прийшов поговорити чи подивитись?"

    menu:
        "Поговорити.":
            mc "Поговорити."

            el "Добре. Бо дивитись на мене — хобі на любителя."

            $ add_chemistry("Елеонор", 2)

        "А є різниця?":
            mc "А є різниця?"

            el "О, величезна. Більшість обирає друге. І думає що я не помічаю."

            $ add_chemistry("Елеонор", 2)

    el "Знаєш, ми можемо зробити це простіше."

    mc "Як саме?"

    el "Ось так."

    # Телепатичний текст — хвильові букви по центру
    $ telepathy("Чуєш мене?")

    menu:
        "...Що це було?":
            mc "...Що це щойно було?"

            el "Телепатія. Мій маленький бонус від Техроту."

            el "Він забрав в мене здоров'я. Але дав... це."

            $ add_chemistry("Елеонор", 2)

        "Я чую тебе. В голові.":
            mc "Я чую тебе. В голові."

            $ telepathy("Не лякайся. Я не кусаюсь.")

            $ telepathy("...Зазвичай.")

            $ add_chemistry("Елеонор", 4)

        "[Мовчати і слухати.]":
            $ telepathy("Мовчун. Цікаво.")

            $ telepathy("Артур такий самий. Але в тебе це інакше звучить.")

            $ add_chemistry("Елеонор", 2)

    el "Не хвилюйся. Я не читаю думки без дозволу."

    el "Ну, майже без дозволу."

    el "Просто інколи простіше... так."

    $ telepathy("Слова на екрані — це обережність. Контроль.")

    $ telepathy("А це — чесність. Без фільтрів.")

    el "Я була журналісткою. До всього цього."

    el "Тепер я — Нікс. Псі-оперативниця. Контроль розуму, все таке."

    el "Техрот змінив моє тіло. Але голова... голова стала гострішою."

    menu:
        "Це лякає?":
            mc "Це лякає? Те що Техрот робить з тобою?"

            el "..."

            $ telepathy("Кожного дня я прокидаюсь і перевіряю чи ще я — це я.")

            el "Але це не тема для першої розмови."

            $ add_chemistry("Елеонор", 4)
            $ add_insight("eleanor_techrot_fear", "Елеонор боїться втратити себе через Техрот. Перевіряє себе щоранку.")

        "Ти сильна.":
            mc "Ти сильна. Не кожен би з цим справився."

            el "Не кажи мені що я сильна, поки не побачиш мене в поганий день."

            el "Але... дякую."

            $ add_chemistry("Елеонор", 2)

        "А Артур знає? Про телепатію?":
            mc "А Артур знає? Що ти можеш... це?"

            el "Артур знає все. Це його благословіння і прокляття."

            el "Він мій брат. Не за кров'ю. За виживання."

            $ add_chemistry("Елеонор", 2)
            $ add_insight("eleanor_arthur_bond", "Елеонор і Артур — не кровні брат і сестра, але зв'язок глибший за кров.")

    el "Марті."

    mc "Так?"

    $ telepathy("Якщо хочеш мене зрозуміти — не слухай що я кажу.")

    $ telepathy("Слухай що я не кажу.")

    el "Все. Іди. В мене справи."

    $ store.seen_dialogues.add("eleanor_intro")
    $ set_flag("eleanor_intro_done")
    $ add_journal_entry("Елеонор — телепатка. Колишня журналістка, тепер Нікс. Техрот змінив її тіло, але загострив розум. Говорить двома способами — словами і думками.", "event")
    $ add_insight("eleanor_telepathy", "Елеонор — телепатка. Може говорити прямо в голову. Хвильовий текст = її думки.")
    $ add_insight("eleanor_nyx", "Елеонор — Нікс. Псі-оперативниця. Контроль розуму.")

    return
