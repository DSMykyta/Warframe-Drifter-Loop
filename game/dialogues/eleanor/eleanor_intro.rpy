# game/dialogues/eleanor/eleanor_intro.rpy
# ═══════════════════════════════════════════════════
# ЕЛЕОНОР — ІНТРО: Телепатія, філософія, Техрот, журналістика
# ═══════════════════════════════════════════════════
# Елеонор говорить ІНАКШЕ від інших — довго, розлого, філософськи.
# Телепатія (хвильовий текст) — її другий голос.
# Вона не питає "як справи" — вона аналізує, провокує, спостерігає.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "eleanor_intro",
        "who": "Елеонор",
        "conditions": {
            "flag_false": ["eleanor_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Привіт, Елеонор.", "eleanor_intro_main"),
        ],
    })


label eleanor_intro_main:

    mc "Привіт, Елеонор."

    el "А."

    el "Привіт."

    el "Ти знаєш, є щось надзвичайно кумедне в тому, як ти підходиш до людей."

    el "Ти кажеш «привіт» так, ніби це слово ще щось означає."

    el "Ніби воно не було зношене до діри мільярдами ротів до тебе."

    el "І це, як не дивно, — зворушливо."

    el "Бо ти кажеш його щиро. Без задньої думки. Без стратегії."

    el "Просто — «привіт». Як дитина, яка ще вірить що цього достатньо."

    $ telepathy("Можливо, це й достатньо.")

    el "Вибач. Я маю звичку думати вголос."

    el "Точніше — думати В ТЕБЕ вголос. Це інша річ."

    menu:
        "Що це було?":
            mc "Що це щойно було? Я почув тебе... але ти не говорила."

            el "Телепатія. Спасибі Техроту."

            el "Він пожирає моє тіло. Повільно, з апетитом. Але натомість дав мені доступ до найцікавішого органу з усіх — чужого мозку."

            el "Не хвилюйся. Я не читаю думки без запрошення."

            el "Ну... майже без запрошення."

            $ add_chemistry("Елеонор", 2)

        "Телепатія. Артур згадував.":
            mc "Телепатія. Артур щось казав."

            el "Артур багато про що каже. Переважно — наказовим тоном."

            el "Але так. Це мій маленький талант. Або прокляття. Залежить від ракурсу."

            $ add_chemistry("Елеонор", 2)

        "[[Просто слухати.]":
            el "Мовчиш. Цікаво."

            $ telepathy("Мовчазні люди — найнебезпечніші. Вони слухають.")

            el "Мені це подобається."

            $ add_chemistry("Елеонор", 4)

    el "Дозволь мені пояснити одну річ."

    el "Бачиш, більшість людей тут спілкуються як люди. Рот, звуки, повітря."

    el "Це неефективно. Неточно. Повно шуму."

    el "Коли ти говориш словами — ти редагуєш. Обираєш що сказати, що приховати."

    el "Це мистецтво. Я поважаю це мистецтво. Я сама була журналісткою."

    el "Але телепатія — це інше."

    $ telepathy("Це — чесність. Без фільтрів. Без масок.")

    $ telepathy("Коли я говорю так — ти чуєш мене справжню.")

    el "Я не завжди буду говорити так. Це стомлює. І лякає людей."

    el "Але іноді — коли мені захочеться бути чесною — ти почуєш хвилі."

    el "І тоді — слухай уважно. Бо те, що я кажу хвилями, я більше не повторю словами."

    menu:
        "Ти довіряєш мені настільки?":
            mc "Ти довіряєш мені настільки? Ми ж щойно познайомились."

            el "Довіра — це не часова функція. Це відчуття."

            el "Я подивилась в тебе під час допиту. Коли Артур тримав меч біля твого горла."

            el "І побачила когось, хто помирав стільки разів, що перестав боятися."

            $ telepathy("Це або мужність, або божевілля.")

            $ telepathy("І те, і те мене цікавить.")

            $ add_chemistry("Елеонор", 4)
            $ add_insight("eleanor_read_drifter", "Елеонор заглянула в мій розум під час допиту. Побачила смерті. Цікавість, не страх.")

        "Яка ти була як журналістка?":
            mc "Журналістка? Де?"

            el "О, скрізь. Де є несправедливість — там є історія. Де є історія — там була я."

            el "Я писала про людей, які ховаються за владою. Людей, які боялись правди більше ніж смерті."

            el "А потім прийшов Техрот. І я стала однією з тих, про кого пишуть."

            el "Іронія — моя улюблена літературна форма."

            $ add_chemistry("Елеонор", 2)
            $ add_insight("eleanor_journalist", "Елеонор була журналісткою. Писала про корупцію і несправедливість. Техрот змінив її роль.")

        "Це лякає.":
            mc "Чесно? Це трохи лякає."

            el "Звісно, що лякає. Хтось говорить тобі в голову. Це має лякати."

            el "Але подумай — що страшніше: голос, який ти чуєш, чи думки, яких не чуєш?"

            el "Більшість людей носять в собі монстрів, яких ніхто ніколи не побачить."

            el "Я хоча б чесна зі своїми."

            $ add_chemistry("Елеонор", 2)

    el "Марті."

    mc "Так?"

    el "Ми ще будемо розмовляти. Багато."

    el "Я бачу в тобі щось... неспокійне. Як дзеркало, в якому відображення рухається окремо від тебе."

    $ telepathy("Але про це потім.")

    $ telepathy("Йди. В мене є над чим подумати.")

    $ store.seen_dialogues.add("eleanor_intro")
    $ set_flag("eleanor_intro_done")
    $ add_journal_entry("Елеонор — телепатка. Журналістка в минулому. Техрот пожирає її тіло, але загострив розум. Два голоси: слова і хвилі. Хвилі — чесність.", "event")
    $ add_insight("eleanor_telepathy", "Елеонор — телепатка. Хвильовий текст = її чесні думки без фільтрів.")
    $ add_insight("eleanor_nyx", "Елеонор — Нікс. Контроль розуму. Була журналісткою.")

    return
