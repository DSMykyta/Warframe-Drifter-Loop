# game/dialogues/aoi/aoi_rank1_convo3.rpy
# Аоі — Ранг 1, Розмова 3: Bubble tea катастрофа

init python:
    DIALOGUE_ENTRIES.append({
        "id": "aoi_rank1_convo3",
        "who": "Аоі",
        "conditions": {
            "flag_false": ["aoi_rank1_convo3_done"],
            "chemistry_min": ("Аоі", 10),
        },
        "priority": 45,
        "chance": 100,
        "titles": [
            ("Чому ти така переляканa?", "aoi_r1c3_how"),
            ("Аоі, що сталось?", "aoi_r1c3_help"),
        ],
    })

label aoi_r1c3_how:
    show aoi at char_center
    mc "Як можна вилити цілий стакан на клавіатуру?"

    ao "Я танцювала."

    mc "...Танцювала."

    ao "В навушниках грала чудова пісня! Я трошки закрутилась і... ну... стакан був на краю столу. Фізика зробила решту."

    mc "Фізика та бабл-ті — небезпечна комбінація."

    ao "Не смійся! Амір мене вб'є. Метафорично. Або буквально. Я не впевнена."

    $ add_chemistry("Аоі", 2)

    jump aoi_r1c3_fix

label aoi_r1c3_help:
    show aoi at char_center

    mc "Тихо. Без паніки. Амір зараз де?"

    ao "На складі. У нас може хвилин двадцять."

    mc "Цього вистачить."

    $ add_chemistry("Аоі", 2)

    jump aoi_r1c3_fix

label aoi_r1c3_fix:

    "Аоі дістає ганчірку і починає витирати, але рідина вже затекла під клавіші."

    ao "Не працює. Воно всередині. Клавіші залипають."

    "Аоі натискає кілька клавіш. Термінал виводить: ППППППРРРРРР."

    ao "Чудово. Тепер комп'ютер заїкається."

    mc "Потрібно розібрати й вичистити."

    ao "Зачекай. У мене є ідея."

    menu:
        "Що за ідея?":
            mc "Слухаю."

            jump aoi_r1c3_mag

        "Тільки не зроби гірше.":
            mc "Аоі, тільки не зроби гірше, благаю."

            ao "Яка недовіра! Зачекай і дивись."

            $ add_chemistry("Аоі", 2)

            jump aoi_r1c3_mag

label aoi_r1c3_mag:

    "Аоі простягає руки над клавіатурою. Повітря навколо її пальців починає мерехтіти."

    ao "Маг — не тільки для бою. Магнітне поле може витягнути металеві частинки з рідини..."

    "Тонкі струмочки рожевої рідини починають підніматися з-під клавіш, ніби в невагомості."

    ao "А якщо змінити полярність... ось так..."

    "Крапля за краплею бабл-ті збирається в повітрі у дрижачу сферу."

    mc "Це... вражає."

    ao "Ще секунду... є!"

    "Аоі направляє сферу рідини у порожній стакан. Кулька тапіоки шльопає останньою."

    ao "Готово. Ідеальна чистота."

    menu:
        "Ти щойно використала бойову здібність для прибирання бабл-ті.":
            mc "Ти щойно використала Маг, варфрейм для магнітної війни... щоб прибрати пролитий чай."

            ao "Імпровізація — мати винахідливості! Або навпаки. Не пам'ятаю."

            mc "Необхідність — мати винаходу."

            ao "Ось! Саме це я мала на увазі."

            $ add_chemistry("Аоі", 4)
            $ add_insight("aoi_mag_creative", "Аоі використовує здібності Маг творчо — не лише для бою. Магнітне поле для побутових проблем.")

        "Вражаючий контроль. Ти добре володієш своїми силами.":
            mc "Серйозно, такий контроль магнітного поля — це не жарт. Ти дуже вправна."

            ao "Дякую! Я багато тренуюсь. Не з бабл-ті, зазвичай. Але принцип той самий."

            $ add_chemistry("Аоі", 4)
            $ add_insight("aoi_mag_precision", "Аоі має дуже точний контроль над магнітними полями. Результат постійних тренувань.")

    "Аоі натискає клавіші. Термінал працює нормально."

    ao "Працює! Амір нічого не дізнається."

    mc "Наша таємниця?"

    ao "Наша таємниця. Перша спільна таємниця, між іншим. Це важливий крок у дружбі!"

    $ add_chemistry("Аоі", 2)

    $ dialogue_end()
    $ store.seen_dialogues.add("aoi_rank1_convo3")
    $ set_flag("aoi_rank1_convo3_done")

    hide aoi
    return
