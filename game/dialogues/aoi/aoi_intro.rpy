# game/dialogues/aoi/aoi_intro.rpy
# ═══════════════════════════════════════════════════
# АОІ — ІНТРО: Примусовий діалог. Вона починає сама.
# ═══════════════════════════════════════════════════
# НЕ через клік. Аоі перехоплює гравця при вході в локацію.
# Реєструється як DIALOGUE_ENTRIES з priority 95 (вище за звичайні інтро).
# В script.rpy location_loop — якщо Аоі в локації і інтро не пройдено,
# автоматично call цей label.
#
# Аоі одразу питає про On-lyne. Без привітання від гравця.

init python:
    # НЕ використовує titles — це примусовий діалог
    DIALOGUE_ENTRIES.append({
        "id": "aoi_intro",
        "who": "Аоі",
        "conditions": {
            "flag_false": ["aoi_intro_done"],
        },
        "priority": 95,
        "chance": 100,
        "forced": True,  # Примусовий — запускається автоматично при вході в локацію
        "label": "aoi_intro",
    })


label aoi_intro:

    ao "О! Ти!"

    ao "Привіт-привіт! Я Аоі!"

    ao "Слухай, поки ти тут — скажи чесно."

    ao "Ти чув On-lyne?"

    mc "On-lyne?"

    ao "Гурт! Вони скрізь! Плакати, радіо, автомати з напоями — всюди їхня пісня."

    ao "Ну, одна пісня. Але яка!"

    ao "«Boys R Back»!"

    menu:
        "Наспівай.":
            mc "Наспівай, може впізнаю."

            ao "Ем..."

            ao "Ні. Ні-ні-ні. Я не співаю при людях."

            ao "Але повір — почуєш і не зможеш забути. В хорошому сенсі!"

            $ add_chemistry("Аоі", 4)

        "Здається чув щось в молі.":
            mc "Здається щось грало з динаміків коли я ходив по молу."

            ao "ТАК! Це вони! Бачиш, вони СКРІЗЬ!"

            $ add_chemistry("Аоі", 2)

        "В майбутньому музика інша.":
            mc "В майбутньому музика... трохи інша."

            ao "Інша як? Краща? Гірша? Є синтезатори??"

            mc "Є... орбітери. З вбудованим радіо."

            ao "Я не знаю що таке орбітер, але якщо там є радіо — я хочу один."

            $ add_chemistry("Аоі", 2)
            $ add_insight("aoi_loves_music", "Аоі обожнює музику. Мріє про радіо на орбітері.")

    ao "Знаєш що мені подобається в On-lyne?"

    ao "Вони грають так, ніби все нормально. Ніби немає Техроту, скальдри, нічого."

    ao "Просто хлопці з гітарами і надією."

    ao "Іноді цього достатньо."

    mc "..."

    ao "Ой, я розговорилась! Вибач."

    ao "Я Аоі. Логістика, координація, магнітні здібності."

    ao "Якщо потрібно знайти щось або когось — приходь до мене. Я в музичному магазині."

    ao "І якщо хочеш послухати On-lyne разом — теж приходь!"

    $ store.seen_dialogues.add("aoi_intro")
    $ set_flag("aoi_intro_done")
    $ add_journal_entry("Аоі — логістик Гексу. Обожнює On-lyne. Грайлива, тепла, щира.", "event")
    $ add_insight("aoi_logistics", "Аоі — логістика і координація. Музичний магазин. Маг.")
    $ add_insight("aoi_observer", "Аоі спостерігає. Помічає те, що інші пропускають.")
    $ add_insight("onlyne_band", "On-lyne — популярний гурт. Одна пісня, але всюди. Аоі фанатка.")

    return
