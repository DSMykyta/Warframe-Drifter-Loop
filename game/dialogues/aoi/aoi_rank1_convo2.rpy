# game/dialogues/aoi/aoi_rank1_convo2.rpy
# Аоі — Ранг 1, Розмова 2: Зброя на підлозі

init python:
    DIALOGUE_ENTRIES.append({
        "id": "aoi_rank1_convo2",
        "who": "Аоі",
        "conditions": {
            "flag_false": ["aoi_rank1_convo2_done"],
            "chemistry_min": ("Аоі", 5),
        },
        "priority": 45,
        "chance": 100,
        "label": "aoi_rank1_convo2",
    })

label aoi_rank1_convo2:
    show aoi at char_center
    $ store.talked_today.add("Аоі")
    $ dialogue_begin()

    ao "Дрифтер, я знайшла щось дивне біля складу. Металева штука, схожа на... не знаю, на що."

    mc "Покажи."

    ao "Ось. Важка, холодна, і вібрує, якщо довго тримати."

    mc "Це уламок теплового леза. Корпусна зброя. Стара модель."

    ao "Корпусна? Тобто з Венери?"

    mc "Так. Корпус базується на Венері. Орбітальні станції, хмарні міста..."

    ao "Зачекай. Хмарні міста? На Венері?"

    menu:
        "Розповісти про Венеру детально":
            jump aoi_r1c2_venus_detail

        "Коротко — там холодно і дивно":
            jump aoi_r1c2_venus_brief

label aoi_r1c2_venus_detail:
    mc "Венера в моєму часі — це не та пекельна планета, про яку ви читали. Корпус терраформував її. Сніг, замерзлі озера, величезні башти."

    ao "Сніг? На Венері? Це... це навпаки від того, що мало бути!"

    mc "Терраформування пішло не за планом. Або саме за планом — залежить від того, кого питаєш."

    ao "Це неймовірно. Люди змінили цілу планету..."

    $ add_chemistry("Аоі", 4)
    $ add_insight("aoi_venus_fascination", "Аоі зачарована ідеєю терраформування Венери. Їй подобається думати про масштабні зміни.")

    jump aoi_r1c2_space

label aoi_r1c2_venus_brief:
    mc "Коротко — там сніг, замерзлі конструкції і дуже багато роботів, які хочуть тебе вбити."

    ao "Сніг і роботи-вбивці. Звучить як новорічний фільм жахів."

    $ add_chemistry("Аоі", 2)

    jump aoi_r1c2_space

label aoi_r1c2_space:

    ao "А інші планети? Ти був скрізь?"

    mc "Марс, Юпітер, Сатурн, навіть далі. Є місця, які важко описати словами."

    ao "Юпітер..."

    mc "Що?"

    ao "Юпітер мене лякає. Завжди лякав."

    mc "Чому?"

    ao "Газовий гігант. Без поверхні. Просто... падаєш. Назавжди. Ніколи не зупинишся. Тільки тиск, що зростає, і темрява."

    menu:
        "На Юпітері є станції. Там можна стояти.":
            mc "В моєму часі Корпус побудував газові платформи. Величезні, як міста. Там є підлога під ногами."

            ao "Підлога над безоднею. Це не краще, Дрифтер. Це навіть гірше."

            mc "Може, ти й маєш рацію."

            $ add_chemistry("Аоі", 2)

        "Розумію цей страх. Безкінечне падіння — це щось особливе.":
            mc "Я розумію. Є щось у самій ідеї — падати без кінця. Це не просто страх висоти."

            ao "Так! Це страх відсутності. Відсутності землі, опори, будь-чого стабільного."

            ao "Ти перший, хто зрозумів це одразу."

            $ add_chemistry("Аоі", 4)
            $ add_insight("aoi_jupiter_fear", "Аоі боїться Юпітера — не висоти, а відсутності опори. Безкінечне падіння без дна.")

    ao "А ті люди, що літають у космос... астронавти. Вони не бояться?"

    mc "У мій час їх називають інакше. Але хоробрі люди є в будь-яку епоху."

    ao "Астронавти. Мені подобається це слово. Зоряні мандрівники."

    ao "Дякую, що розповів. Тепер я буду думати про сніг на Венері замість безодні Юпітера."

    $ dialogue_end()
    $ store.seen_dialogues.add("aoi_rank1_convo2")
    $ set_flag("aoi_rank1_convo2_done")

    hide aoi
    return
