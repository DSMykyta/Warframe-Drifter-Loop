# game/dialogues/amir/amir_rank1_convo4.rpy
# Амір — Ранг 1, Розмова 4: Про себе та Квінсі

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_rank1_convo4",
        "who": "Амір",
        "conditions": {
            "flag_true": ["amir_intro_done", "amir_rank1_convo3_done"],
            "flag_false": ["amir_rank1_convo4_done"],
            "rank_min": 1,
        },
        "priority": 45,
        "chance": 100,
        "label": "amir_rank1_convo4",
    })

label amir_rank1_convo4:
    show amir at char_center
    $ store.talked_today.add("Амір")
    $ dialogue_begin()

    mc "Амір, можна тебе дещо запитати?"

    am "Ого, звучить серйозно! Давай!"

    menu:
        "Що між тобою і Квінсі?":
            jump amir_r1c4_quincy

        "Розкажи щось про себе.":
            jump amir_r1c4_about

label amir_r1c4_quincy:
    am "Він — зануда і зловредник. Іноді."

    am "А іноді — найкращий чувак на світі."

    am "Ненавиджу його, помер би за нього, він мені як брат, якого хочеться задушити."

    am "Повільно."

    am "З насолодою."

    am "А ЧОМУ, МІЖ НАМИ ЩОСЬ ПОМІТНО?"

    menu:
        "Просто не розумію, чому ви один одного дістаєте.":
            am "Я — специфічний смак. Як марочне вино."

            am "Якщо те вино було б наповнене гіперактивними бджолами."

            am "Я його дратую. Взагалі-то це історія мого життя."

            menu:
                "Ти буваєш надто енергійний, але ти щирий і добрий.":
                    am "Ой... У мене щоки горять."

                    am "Дякую. Серйозно."

                    am "О! Це підказало мені ідею для нового розіграшу Квінсі! Побіг!"

                    $ add_chemistry("Амір", 4)
                    $ add_insight("amir_quincy_dynamic", "Амір і Квінсі — як брати. Амір знає, що дратує людей, але це його спосіб проявляти любов.")

                "Ти мене не дратуєш.":
                    am "Мило з твого боку, але ти ще не бачив мене на повну потужність."

                    am "Ну ладно, пішов вигадувати розіграш для Квінсі!"

                    $ add_chemistry("Амір", 2)
                    $ add_insight("amir_self_aware", "Амір усвідомлює, що його енергія дратує інших. Але це частина його захисту.")

        "Ого. Серйозні пристрасті.":
            am "такнапевноцебулозабагатоправда"

            am "Е-е-е... Мені треба піти пробігтися."

            $ add_chemistry("Амір", 2)

    jump amir_r1c4_end

label amir_r1c4_about:
    am "Ой, справді? Про мене?"

    am "Ну... Не знаю з чого почати. У мене виконавча дисфункція спрацьовує саме в такі моменти."

    am "І повір, я вкладаю ВЕСЬ фан у дисФАНкцію!"

    am "ПРО ЩО МИ ВЗАГАЛІ ГОВОРИЛИ?"

    menu:
        "Яка твоя улюблена їжа?":
            am "О! Це легко! Пад тай!"

            am "Ой, а може, підемо разом поїсти пад тай?!"

            menu:
                "Із задоволенням!":
                    am "Клас!"

                    $ add_chemistry("Амір", 4)
                    $ set_flag("amir_padthai_date")
                    $ add_insight("amir_fav_food", "Улюблена їжа Аміра — пад тай. Ми домовились піти поїсти разом.")

                "Може, якось потім.":
                    am "Без проблем! Пропозиція завжди в силі!"

                    $ add_chemistry("Амір", 2)
                    $ add_insight("amir_fav_food", "Улюблена їжа Аміра — пад тай.")

        "Який твій улюблений колір?":
            am "Синій! Що дуже зручно, зважаючи на всі ці блискавки."

            am "А чому питаєш? Збираєшся мені щось подарувати?"

            am "Хммммммм?"

            menu:
                "Ну, тепер доведеться.":
                    am "ОБІЦЯНКА!"

                    $ add_chemistry("Амір", 4)
                    $ set_flag("amir_gift_hinted")
                    $ add_insight("amir_fav_color", "Улюблений колір Аміра — синій. Обіцяв йому щось подарувати.")

                "Так, але зроби вигляд, що це сюрприз, добре?":
                    am "КЛЯНУСЬ!"

                    $ add_chemistry("Амір", 2)
                    $ add_insight("amir_fav_color", "Улюблений колір Аміра — синій. Пов'язаний з його блискавками (Вольт).")

    jump amir_r1c4_end

label amir_r1c4_end:

    am "Дрифтер?"

    mc "Так?"

    am "Дякую, що... ну, спілкуєшся зі мною нормально. Не всі так роблять."

    mc "Не дякуй. Мені подобається з тобою розмовляти."

    am "...Ну все, я побіг, бо якщо залишусь, скажу щось тупе й зіпсую момент."

    $ dialogue_end()
    $ store.seen_dialogues.add("amir_rank1_convo4")
    $ set_flag("amir_rank1_convo4_done")
    $ set_flag("amir_rank1_complete")
    $ add_insight("amir_beneath_surface", "За гіперактивністю Аміра ховається вдячність за просту людську увагу.")

    hide amir
    return
