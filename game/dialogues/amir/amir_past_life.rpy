# game/dialogues/amir/amir_past_life.rpy
# Амір розповідає про своє минуле — хлопчик, що лагодив радіо, поки війна не забрала все

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_past_life",
        "who": "Амір",
        "conditions": {
            "flag_true": ["amir_nightmares_done"],
            "flag_false": ["amir_past_life_done"],
            "rank_min": 3,
            "chemistry_min": ("Амір", 80),
        },
        "priority": 50,
        "chance": 100,
        "label": "amir_past_life",
    })

label amir_past_life:
    show amir at char_center
    $ store.talked_today.add("Амір")

    am "Ти питав про кошмари. Я не відповів тоді. Але зараз..."
    $ advance_time(5)

    am "Зараз я хочу розповісти. Не про сни. Про те, що було до них."
    $ advance_time(5)

    mc "Я слухаю."
    $ advance_time(5)

    am "Мені було дев'ять. Ми жили на околиці міста, якого вже не існує. Мій батько мав майстерню — радіоприймачі, транзистори, паяльники."
    $ advance_time(5)

    am "Я сидів у нього на колінах і дивився, як він з'єднує дроти. Для мене це була магія. Торкаєшся двох проводів — і мертва коробка починає говорити."
    $ advance_time(5)

    am "Він казав: \"Амір, кожна зламана річ хоче бути полагодженою. Треба просто знайти, де болить.\""
    $ advance_time(5)

    mc "Що сталося з майстернею?"
    $ advance_time(5)

    am "Те саме, що з усім. Війна. Не та, про яку пишуть у підручниках. Тиха, повільна, яка з'їдає місто квартал за кварталом."
    $ advance_time(5)

    am "Одного ранку я прийшов у майстерню — а там діра в стіні. Радіо розбиті. Паяльник розплавлений. Батька не було. Більше ніколи не було."
    $ advance_time(5)

    menu:
        "Мені шкода, Амір.":
            $ advance_time(5)
            mc "Мені шкода, Амір."
            am "Не треба шкодувати. Він навчив мене головного — лагодити. Навіть коли здається, що полагодити неможливо."
            $ advance_time(5)

        "Тому ти лагодиш все?":
            $ advance_time(5)
            mc "Тому ти лагодиш все?"
            am "Так. Кожен генератор, кожну плату, кожен дріт — я лагоджу за нього. Тому що він більше не може."
            $ advance_time(5)

    am "Кошмари — це палаюча майстерня. Знову і знову. Схеми кричать його голосом. А я стою і не можу торкнутись."
    $ advance_time(5)

    am "Але вдень — вдень я беру паяльник і роблю те, що він мене навчив. І поки я це роблю — він живий. Десь у моїх руках. У кожному з'єднанні."
    $ advance_time(5)

    am "...Ну ось. Тепер ти знаєш. Весь Амір. Без жартів, без рекордів. Просто хлопчик, який лагодив радіо."
    $ advance_time(5)

    $ store.seen_dialogues.add("amir_past_life")
    $ set_flag("amir_past_life_done")
    $ add_insight("amir_origin", "Амір був сином радіомайстра — війна забрала батька і майстерню але не вміння лагодити і не пам'ять")

    hide amir
    return
