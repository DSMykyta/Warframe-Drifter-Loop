# game/dialogues/amir/amir_intro.rpy
# ═══════════════════════════════════════════════════
# АМІР — ІНТРО: Пейджер + хто такий Марті
# ═══════════════════════════════════════════════════

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_intro",
        "who": "Амір",
        "conditions": {
            "flag_false": ["amir_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Йо, Амір.", "amir_intro_main"),
        ],
    })


label amir_intro_main:

    am "О! Марті! Якраз тебе шукав."

    am "Тримай."

    $ set_flag("has_pager")
    show screen pager_hud

    am "Це пейджер. Ну, як телефон. Тільки гірше. Набагато гірше."

    if is_loop_restart():
        # ═══ ПЕТЛЯ 2+: скорочено, без туторіалу і Марті ═══
        mc "Та я знаю, Аміре. Це не перший мій раз."

        am "...Шо?"

        mc "Не зважай. Дякую."

        am "Окей... дивний ти, Марті."

        am "Ну все. Пейджер є, карта є. Давай, не загуби нічого."

        $ store.seen_dialogues.add("amir_intro")
        $ set_flag("amir_intro_done")
        $ add_journal_entry("Амір дав пейджер.", "event")
        $ add_insight("pager_system", "Пейджер — зв'язок з Гексом.")
        return

    # ═══ ПЕТЛЯ 1: Повне пояснення ═══

    menu:
        "Що це за цеглина?":
            mc "Що це за цеглина?"

            am "ХА! Це ж пейджер! Ти шо, з майбутнього??"

            mc "..."

            am "О. Точно. Ти ж реально з майбутнього."

            am "Окей, окей. Пояснюю."

        "Дякую... а нащо він мені?":
            mc "Дякую... а нащо він мені?"

            am "О, тобі він ДУЖЕ потрібен. Повір. Пояснюю."

    am "Бачиш екранчик? Зелений такий, мерехтить."

    am "Там час, день, де ти зараз, скільки грошей, репутація Гексу — базові речі."

    am "Але головне — повідомлення."

    am "У кожного з нас є такий. Люди пишуть, ти читаєш."

    am "Типу... о, дивись!"

    $ add_pager_message("Аоі", "Я знайшла новий дист on-lyne! >=D")
    $ add_pager_message("Артур", "Не смій вмикати на весь торгівельний центр.")

    am "Бач? Аоі вже щось написала. І Артур теж — як завжди."

    am "Натисни центральну кнопку — побачиш повідомлення. Давай, спробуй."

    # ═══ ПАУЗА: чекаємо кнопку пейджера ═══
    $ start_action_wait()
    call screen wait_for_action
    $ _btn = _return
    $ end_action_wait()

    if _btn == "center":
        am "Бачиш? Перемикає між статусом і повідомленнями."

        am "Можеш гортати — зелена і червона кнопки."

        am "А центральна знов — назад на статус."

    elif _btn == "left":
        am "Ні-ні, це зелена. Центральна — та що посередині."

        am "Але не страшно, розберешся. Центральна перемикає, бокові гортають."

    elif _btn == "right":
        am "Це червона. Центральна — посередині."

        am "Але окей, суть зрозуміла. Центральна перемикає, бокові гортають."

    am "А тепер дивись. Іноді приходить не просто повідомлення, а запит на допомогу."

    am "Треба відповісти: так чи ні."

    $ pager_send_request("Летті", "Допоможи перенести коробки медикаментів?", None, None)

    am "О! Летті просить допомогти перенести коробки."

    am "Зелена кнопка зліва — прийняти. Червона справа — відхилити."

    am "Зараз відхили — я ще не закінчив пояснювати."

    # ═══ ПАУЗА: чекаємо кнопку пейджера ═══
    $ start_action_wait()
    call screen wait_for_action
    $ _btn2 = _return
    $ end_action_wait()

    if _btn2 == "right":
        am "Ось. Відхилено."

        am "Але запам'ятай — якщо вільний і хтось просить, йди. Бо це репутація."

        am "А репутація — це довіра. А довіра тут — валюта."

        $ add_chemistry("Амір", 2)

    elif _btn2 == "center":
        am "...Це центральна. Ти просто закрив запит."

        am "Ну... технічно теж варіант. Просто проігнорив."

        am "Краще відповідай. Ігнор теж помітять."

        $ add_chemistry("Амір", 1)

    elif _btn2 == "left":
        am "Стій-стій! Я ж сказав — відхили!"

        am "Летті тепер думає що ти йдеш допомагати."

        mc "..."

        am "...Ладно, нічого. Скажу їй що ти випадково натиснув."

        am "Запам'ятай: зелена — підтверджуєш. Червона — відмовляєш."

        $ add_chemistry("Амір", 2)

    # Скинути запит, але лишити повідомлення від Аоі та Артура
    $ store.pager_mode = "status"
    $ store.pager_request_who = ""
    $ store.pager_request_text = ""
    $ store.pager_request_accept = None
    $ store.pager_request_decline = None
    $ store.pager_unread = False

    am "А! І ще."

    am "Якщо домовився з кимось зустрітись — пейджер нагадає. Щоб не забув."

    am "Бо якщо забудеш... ну... люди тут не дуже це прощають."

    # ═══ МАРТІ ═══

    mc "До речі, Аміре."

    mc "Хто такий Марті? Чому ви мене так називаєте?"

    am "О-о-о, брат. Ти не знаєш??"

    am "Марті МакФлай! Фільм! «Назад у Майбутнє»!"

    am "Хлопець потрапляє в минуле, все ламає, потім фіксить."

    am "Ти ж теж з майбутнього і все тут ламаєш, ні?"

    menu:
        "Я ще нічого не зламав.":
            mc "Я ще нічого не зламав."

            am "Поки що. ПОКИ ЩО, Марті."

            am "Але серйозно — це комплімент. Марті класний."

            $ add_chemistry("Амір", 2)

        "Грубо. Але смішно.":
            mc "Грубо. Але смішно."

            am "ДЯКУЮ. Я старався."

            $ add_chemistry("Амір", 4)
            $ add_insight("marty_meaning", "Марті МакФлай — герой фільму 'Назад у Майбутнє'. Амір вважає це компліментом.")

        "Мені все одно як мене називають.":
            mc "Мені все одно як мене називають."

            am "...Ну добре. Але ти все одно Марті."

    am "Слухай, а ти кіно любиш?"

    menu:
        "Якщо чесно, майже не дивився.":
            mc "Якщо чесно, я майже не дивився фільмів. Ну... обставини."

            am "ШООО?! Це ж ЗЛОЧИН!"

            am "Окей, все. Ми сідаємо і дивимось. Обов'язково. Я тобі складу список."

            $ set_flag("amir_movie_night_promised")
            $ add_chemistry("Амір", 4)
            $ add_insight("amir_loves_movies", "Амір фанат кіно. Обіцяв скласти список фільмів для мене.")

        "Люблю, але тут не до кіна.":
            mc "Люблю. Але зараз не найкращий час для кіновечорів."

            am "Час ЗАВЖДИ є для кіна, Марті. Запам'ятай це."

            $ set_flag("amir_movie_night_promised")
            $ add_chemistry("Амір", 2)

        "Ні.":
            mc "Ні, не моя тема."

            am "...Ми це виправимо. Повір мені."

            $ set_flag("amir_movie_night_promised")

    $ store.seen_dialogues.add("amir_intro")
    $ set_flag("amir_intro_done")
    $ add_journal_entry("Амір дав пейджер. Час, повідомлення, запити допомоги — все на ньому.", "event")
    $ add_insight("pager_system", "Пейджер — зв'язок з Гексом. Запити допомоги, час, репутація.")

    return
