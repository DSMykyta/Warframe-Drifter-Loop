# game/dialogues/amir/amir_rank1_convo3.rpy
# Амір — Ранг 1, Розмова 3: Роботи, роботи, роботи

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_rank1_convo3",
        "who": "Амір",
        "conditions": {
            "flag_false": ["amir_rank1_convo3_done"],
            "chemistry_min": ("Амір", 10),
        },
        "priority": 45,
        "chance": 100,
        "titles": [
            ("Ти шо, знову на енергетиках?", "amir_r1c3_science"),
            ("Привіт! Ти чомусь аж підстрибуєш.", "amir_r1c3_fair"),
        ],
    })

label amir_r1c3_science:
    show amir at char_center
    am "Ахаха!"

    mc "Але це якось іншим разом. Давай до теми."

    jump amir_r1c3_topic

label amir_r1c3_fair:
    show amir at char_center

    am "Ну так, логічно."

    jump amir_r1c3_topic

label amir_r1c3_topic:

    mc "Отже, коли ти кажеш «роботи», ти маєш на увазі щось типу штучного інтелекту?"

    am "Так-так-так! Саме це!"

    mc "Гаразд. Є кілька видів."

    menu:
        "Розповісти про Сентієнтів":
            jump amir_r1c3_sentients

        "Розповісти про Цефалонів":
            jump amir_r1c3_cephalons

        "Розповісти про дронів Корпусу":
            jump amir_r1c3_drones

label amir_r1c3_sentients:
    mc "Є Сентієнти. Надзвичайно розвинена штучна раса."

    mc "Їх створили для терраформування нової планети — Тау."

    am "Ого..."

    mc "На жаль, більшість із них намагається нас убити."

    am "А чому?"

    menu:
        "Вони бояться, що ми зруйнуємо Тау, як зруйнували Землю.":
            am "Ох... знову все заскладно, так?"

            am "Давай краще повернемось до технічних деталей."

            am "Далі, далі!"

            $ add_chemistry("Амір", 2)
            $ add_insight("amir_sentients_intro", "Розповів Аміру про Сентієнтів. Його більше цікавить техніка, ніж політика.")

        "Довга історія. Стара Війна.":
            am "Ой, це знову та територія де мозок плавиться..."

            am "Повернемось до цікавого!"

            $ add_chemistry("Амір", 2)

    jump amir_r1c3_second_topic

label amir_r1c3_cephalons:
    mc "Є Цефалони. Технічно не роботи, але високі технології."

    mc "Це щось на кшталт законсервованої особистості. Скляний мозок."

    am "Скляний мозок? А можна детальніше?"

    mc "Цефалони — це цифрово збережені свідомості. Їх можна... змінювати."

    am "Змінювати? Як, характер?"

    menu:
        "Саме так. Для деяких це було покаранням.":
            am "Покаранням? Та ну, не так вже й погано."

            am "Жити вічно як великий скляний мозок у банці!"

            mc "Вони не в банках. Наскільки я знаю, вони обирають собі тіла."

            am "ЩЕ КРАЩЕ! Я БИ ХОТІВ БУТИ ТАНКОМ!"

            am "АБО РОБОТИЧНИМ МАНГУСТОМ!"

            am "ЧИ МОЖНА БУТИ МАНГУСТО-ТАНКОМ?!"

            mc "Чому мангуст?"

            am "Злий. Маленький. Кусючий. ГРРР!"

            $ add_chemistry("Амір", 4)
            $ add_insight("amir_cephalon_dream", "Амір хоче стати Цефалоном у тілі мангусто-танка. Серйозно.")

        "Так. Виглядає дивно, але їм подобається.":
            am "Жити вічно, обирати тіло... Де записатись?!"

            am "Я хочу бути летючим мангустом з лазерами!"

            $ add_chemistry("Амір", 2)
            $ add_insight("amir_cephalon_interest", "Амір зацікавився ідеєю Цефалонів.")

    jump amir_r1c3_second_topic

label amir_r1c3_drones:
    mc "Є дрони Корпусу. Ось це — справжня робототехніка."

    mc "Оспреї, розорбеки, гончаки, МОА, раптори..."

    am "КРУТО!"

    mc "Ага, у мене навіть є роботизовані вихованці. Вони допомагають у бою."

    am "ЩО?!"

    am "ТРЕБА БУЛО З ЦЬОГО ПОЧИНАТИ!"

    am "Це як та штука, коли я прикрутив колеса й ніж до свого Кінеготчі!"

    am "Тільки набагато крутіше."

    am "...Квінсі тоді так злився, коли Кінеготчі проїхав йому по гомілці."

    menu:
        "Це геніально.":
            am "ОСЬ БАЧИШ! Хтось мене розуміє!"

            am "А всі інші тільки скиглили, ніби ми не регенеруємо як скажені."

            am "Він був такий гарненький! У такому брутальному стилі — скотч та кухонний ніж."

            am "О! ЦЕ ПІДКАЗАЛО МЕНІ ЧУДОВУ ІДЕЮ!"

            mc "Може, попередити інших?"

            am "Тссс! Все буде чудово!"

            $ add_chemistry("Амір", 4)
            $ set_flag("amir_kinegotchi_idea")
            $ add_insight("amir_kinegotchi", "Амір колись прикрутив ніж до свого Кінеготчі. Квінсі досі не пробачив. Тепер у Аміра нова ідея...")

        "Наші трохи просунутіші.":
            am "Ну так, в майбутньому все просунутіше. Але суть та сама — бойові домашні улюбленці!"

            $ add_chemistry("Амір", 2)

    jump amir_r1c3_second_topic

label amir_r1c3_second_topic:

    am "Мені треба це все обдумати."

    am "Голова вже гуде, але це НАЙКРАЩЕ гудіння в моєму житті!"

    am "Дякую, Дрифтер. Серйозно."

    jump amir_r1c3_end

label amir_r1c3_end:

    $ dialogue_end()
    $ store.seen_dialogues.add("amir_rank1_convo3")
    $ set_flag("amir_rank1_convo3_done")

    hide amir
    return
