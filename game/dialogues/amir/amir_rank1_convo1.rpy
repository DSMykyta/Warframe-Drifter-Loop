# game/dialogues/amir/amir_rank1_convo1.rpy
# Амір — Ранг 1, Розмова 1: Вікторина з майбутнього

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_rank1_convo1",
        "who": "Амір",
        "conditions": {
            "flag_false": ["amir_rank1_convo1_done"],
            "chemistry_min": ("Амір", 0),
        },
        "priority": 50,
        "chance": 100,
        "titles": [
            ("Привіт! Що нового?", "amir_r1c1_pick_topic"),
            ("Чо такий збуджений?", "amir_r1c1_complicated"),
            ("Вибач, зараз зайнятий.", "amir_r1c1_end"),
        ],
    })

label amir_r1c1_complicated:
    show amir at char_center
    am "Обожнюю складні історії!"

    am "Я колись вивчив усі правила настільної гри на вісімдесят сторінок за одну ніч."

    am "Давай, розповідай. Я все проковтну."

    mc "Гаразд. Ось, наприклад, Корпус..."

    mc "Це такі фанатики прибутку з армією роботів. Їхній засновник Парвос Грейнум — колишній фермер, який побудував торговий культ."

    mc "Усі думали, що його вбили, але він сховався у Бездолі Грейнум, тож, напевно, трохи з'їхав..."

    mc "А ще є Сентієнти — штучна раса, яка зазвичай ворожа, окрім Лотос, яка не ворожа, але її зовнішність базується на—"

    am "Стоп-стоп-стоп! Гальма!"

    am "Я передумав. Це ЗАНАДТО складно для одного разу."

    am "З цього нічого не затримається в голові."

    jump amir_r1c1_encyclopedia

label amir_r1c1_pick_topic:
    show amir at char_center

    am "Е-е-е..."

    am "Блін, не роби так! Я не можу обрати!"

    am "Коли стільки варіантів, мій мозок просто... зависає."

    mc "Добре, тоді я сам. Є такі Грінір — армія генетичних клонів..."

    mc "Спочатку їх створили як робочу силу, потім мілітаризували. У них божевільна Королева, а їхні тіла поступово деградують..."

    mc "А ще є Орокін — стародавня цивілізація, яка правила всією системою. Деякі з них навчились жити вічно через ритуал, що називається Безперервність..."

    mc "Вони переносили свідомість у чуже тіло за допомогою Куви, і—"

    am "Зачекай! Тайм-аут! Це все неймовірно, але голова зараз вибухне!"

    am "Мені потрібна якась система, щоб це все засвоїти."

    jump amir_r1c1_encyclopedia

label amir_r1c1_encyclopedia:

    am "О! Слухай! Нам потрібна... енциклопедія!"

    am "Така штука, де можна все записати!"

    am "І ЗРОБИТИ ЇЇ ОНЛАЙН! Щоб усі могли додавати інформацію!"

    am "Я ГЕНІЙ!"

    am "Тільки треба круту назву... Я жахливо вигадую назви. Давай ти."

    menu:
        "АМІР4Ю":
            am "Хм... звучить як канал на ютубі. Але мені подобається!"

            am "Ладно, погнали! Будемо творити!"

            $ add_chemistry("Амір", 2)

        "Аміракл":
            am "Пффф-ахахахаха!"

            am "ПРОДАНО! Це ідеально!"

            am "Ну що, закочуємо рукави!"

            $ add_chemistry("Амір", 4)
            $ add_insight("amir_encyclopedia", "Амір хоче створити онлайн-енциклопедію про майбутнє. Назва: Аміракл.")

        "Гексіонарій":
            am "Ладно, поділимось славою... Якщо мусимо."

            am "Гексіонарій... Ну, для командного проєкту непогано!"

            $ add_chemistry("Амір", 2)

    am "Ну все, час братися за роботу!"

    $ set_flag("amir_encyclopedia_started")

    jump amir_r1c1_end

label amir_r1c1_end:
    show amir at char_center

    $ dialogue_end()
    $ store.seen_dialogues.add("amir_rank1_convo1")
    $ set_flag("amir_rank1_convo1_done")

    hide amir
    return
