# game/dialogues/amir/amir_loyalty_deep.rpy
# Амір пояснює глибше, чому він вірний Артуру — той побачив у ньому більше

init python:
    DIALOGUE_ENTRIES.append({
        "id": "amir_loyalty_deep",
        "who": "Амір",
        "conditions": {
            "flag_true": ["amir_loyalty_done"],
            "flag_false": ["amir_loyalty_deep_done"],
            "rank_min": 3,
            "chemistry_min": ("Амір", 60),
        },
        "priority": 50,
        "chance": 100,
        "label": "amir_loyalty_deep",
    })

label amir_loyalty_deep:
    show amir at char_center
    $ store.talked_today.add("Амір")

    am "Я тобі розповідав, як Артур мене знайшов. Але не розповідав, що було після."
    $ advance_time(5)

    mc "Після підсобки?"
    $ advance_time(5)

    am "Після підсобки мене посадили біля генератора і сказали — полагоди. Я полагодив за двадцять хвилин. Знаєш, що сказали інші? \"Корисний пацан.\""
    $ advance_time(5)

    am "Корисний. Як інструмент. Як викрутка, що говорить."
    $ advance_time(5)

    mc "А Артур?"
    $ advance_time(5)

    am "Артур підійшов, сів поруч і спитав: \"Як тебе звати?\" Не \"що ти вмієш\". Не \"де ти навчився\". Просто — ім'я."
    $ advance_time(5)

    am "Ніхто не питав мого імені місяцями. Я мало не забув його. Серйозно. Мало не забув, що я — Амір."
    $ advance_time(5)

    menu:
        "Він побачив у тобі людину.":
            $ advance_time(5)
            mc "Він побачив у тобі людину."
            am "Так. Вперше за довгий час. І знаєш, що найсмішніше? Він навіть не вважає це чимось особливим. Для нього це просто — нормально."
            $ advance_time(5)

        "Тому ти зробиш для нього все?":
            $ advance_time(5)
            mc "Тому ти зробиш для нього все?"
            am "Не \"все\". Я не сліпий фанатик. Але я знаю, що Артур ніколи не попросить мене зробити те, чого я не зможу витримати."
            $ advance_time(5)

    am "Лояльність — це не коли тебе змушують. Це коли тебе бачать. Артур побачив Аміра, а не \"технічну мавпу\". І за це я буду поруч, поки він мене не проженить."
    $ advance_time(5)

    am "А він не проженить. Бо хто ще полагодить генератор за двадцять хвилин?"
    $ advance_time(5)

    $ store.seen_dialogues.add("amir_loyalty_deep")
    $ set_flag("amir_loyalty_deep_done")
    $ add_insight("amir_arthur_bond", "Артур був першим хто спитав Аміра як його звати — не що він вміє а хто він є")

    hide amir
    return
