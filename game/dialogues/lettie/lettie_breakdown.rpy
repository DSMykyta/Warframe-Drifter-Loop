# game/dialogues/lettie/lettie_breakdown.rpy
# Летті розповідає про пацієнта, якого не врятувала — перший раз без сарказму

init python:
    DIALOGUE_ENTRIES.append({
        "id": "lettie_breakdown",
        "who": "Летті",
        "conditions": {
            "flag_true": ["lettie_why_medic_done"],
            "flag_false": ["lettie_breakdown_done"],
            "rank_min": 3,
            "chemistry_min": ("Летті", 80),
        },
        "priority": 50,
        "cooldown_tag": "heavy_lore",
        "chance": 100,
        "label": "lettie_breakdown",
    })

label lettie_breakdown:
    show letty at char_center
    $ store.talked_today.add("Летті")

    le "Сядь. Будь ласка."
    $ advance_time(5)

    mc "Летті? Все гаразд?"
    $ advance_time(5)

    le "Ні. Не все гаразд. Давно не все гаразд, але сьогодні... сьогодні гірше."
    $ advance_time(5)

    le "Рік тому. Може, два — в петлі рахувати безглуздо. Був хлопець. Двадцять три роки. Осколок у грудній клітці, міліметри від серця."
    $ advance_time(5)

    le "Я знала, що робити. Я мала інструменти. Мала час. Мала все."
    $ advance_time(5)

    mc "Що сталося?"
    $ advance_time(5)

    le "Мої руки тремтіли. Вперше за все життя — тремтіли. Я дивилась на нього, і він дивився на мене, і я бачила, що він знає."
    $ advance_time(5)

    le "Він знав, що я боюся. І замість того, щоб кричати, він сказав: \"Нічого, Летті. Ти робиш все правильно.\""
    $ advance_time(5)

    le "Пацієнт заспокоював медика. Уявляєш?"
    $ advance_time(5)

    menu:
        "Він не вижив?":
            $ advance_time(5)
            mc "Він не вижив?"
            le "Він не вижив. Осколок зсунувся, коли я його діставала. Артерія. Тридцять секунд — і все."
            $ advance_time(5)
            le "Тридцять секунд. Я рахувала. Я завжди рахую."
            $ advance_time(5)

        "Летті...":
            $ advance_time(5)
            mc "Летті..."
            le "Не треба. Не кажи, що \"це не моя вина\". Я знаю, чия це вина. Мої руки. Мій страх. Моя провина."
            $ advance_time(5)
            le "Він довірив мені своє життя. А я довірила своїм рукам. І ми обидва програли."
            $ advance_time(5)

    le "З того дня я не тремчу. Ніколи. Мої руки — як камінь. Тому що я пам'ятаю, що буває, коли вони ні."
    $ advance_time(5)

    le "Сарказм, цинізм, кава — це все стіни. А за стінами — хлопець, якому було двадцять три, який заспокоював мене, поки помирав."
    $ advance_time(5)

    le "Я не плачу. Не дозволяю собі. Але іноді, вночі, коли Канела спить у мене на плечі, я думаю — чи пробачив би він мене?"
    $ advance_time(5)

    le "...Дякую, що слухаєш. Більше я цього не повторю."
    $ advance_time(5)

    $ store.seen_dialogues.add("lettie_breakdown")
    $ set_flag("lettie_breakdown_done")
    $ add_insight("lettie_guilt", "Летті втратила пацієнта через тремтячі руки — тепер її руки ніколи не тремтять але вина залишилась назавжди")

    hide letty
    return
