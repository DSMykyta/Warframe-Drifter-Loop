# game/dialogues/lettie/lettie_rank1_convo4.rpy
# Летті — Ранг 1, Розмова 4: Чи є ще боги? Сол і Луна.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "lettie_rank1_convo4",
        "who": "Летті",
        "conditions": {
            "flag_false": ["lettie_rank1_convo4_done"],
            "chemistry_min": ("Летті", 18),
        },
        "priority": 45,
        "chance": 100,
        "titles": [
            ("Є хвилинка? Хотів спитати.", "lettie_r1c4_hell_of_a_way"),
            ("Летті, все гаразд?", "lettie_r1c4_back_up"),
            ("Слухай, можу питання?", "lettie_r1c4_no_gods"),
        ],
    })

label lettie_r1c4_hell_of_a_way:
    show lettie at char_center
    mc "У тебе чудовий спосіб починати розмову, знаєш?"

    le "Хе, знаю. Звикнеш. Або ні."

    le "Ну? Їм ще поклоняються? Сол і Луна?"

    jump lettie_r1c4_gods_question

label lettie_r1c4_back_up:
    show lettie at char_center

    mc "Зачекай, що? Які боги?"

    le "Серйозно, бабас? Боги — Сол і Луна. Їх пам'ятають?"

    jump lettie_r1c4_gods_question

label lettie_r1c4_gods_question:
    menu:
        "Їм не поклоняються як богам. Але Луна досі вважається священною.":
            jump lettie_r1c4_lua_sacred

        "Складно пояснити. Луна досі дуже важлива, але їй не поклоняються.":
            jump lettie_r1c4_what_worship

        "Я виріс поклоняючись Орокін. А потім порозумнішав.":
            jump lettie_r1c4_no_gods

label lettie_r1c4_lua_sacred:
    mc "Їм не поклоняються як богам. Вибач. Але Луна досі вважається чимось... священним."

    le "Що значить — чимось священним?"

    mc "Луну... ну... на якийсь час засунули у Безодню."

    le "Якщо це хоча б наполовину те, що звучить — ви її КУДИ засунули?!"

    menu:
        "Безодня — це щось на кшталт не-виміру. Чорно-білий. Дивний. Трохи колеться.":
            jump lettie_r1c4_duviri

        "Я був у Дувірі, помирав раз за разом, коли Лотос вирішила засунути Луну в Безодню.":
            jump lettie_r1c4_duviri

label lettie_r1c4_what_worship:
    mc "Складно пояснити. Довга історія. Коротко — Луна досі важлива, але їй не поклоняються."

    le "Тоді чому ви поклоняєтесь?"

    menu:
        "Всесвіту. Безодні. Всьому.":
            mc "Всесвіту. Безодні. Всьому."

            le "Поетично. Але порожньо."

            jump lettie_r1c4_end

        "Нічому.":
            mc "Нічому."

            le "Хм. Чесно, принаймні."

            $ add_chemistry("Летті", 2)

            jump lettie_r1c4_end

        "Вірю в себе і людей навколо.":
            jump lettie_r1c4_believe_people

label lettie_r1c4_believe_people:
    mc "Вірю в себе і людей навколо."

    mc "Коли помираєш по колу без кінця — це робить своє."

    le "Це мотиваційний плакат, а не віра. Але якщо тобі з цим спокійніше вночі..."

    le "Хоча мені цікаво. Це твоє царство смерті — розкажи більше."

    jump lettie_r1c4_duviri

label lettie_r1c4_duviri:
    mc "Дувірі — це альтернативний вимір, який я ніби... створив? Своїм існуванням?"

    mc "Безодня витягла зі мого розуму образи і зробила їх реальними. Прояви переляканої дитини."

    mc "Але все пішло шкереберть, коли я виріс і захотів піти. І вони почали вбивати мене. Знову і знову."

    le "Історії, що стали реальністю... А Смерть знає твоє обличчя."

    le "Може, у нас більше спільного, ніж я думала, бабас."

    $ add_chemistry("Летті", 4)
    $ add_insight("lettie_la_flaca", "Летті називає смерть 'Ла Флака'. Бачить паралель між своїм досвідом і петлею Дрифтера у Дувірі.")

    menu:
        "Ти дивна жінка...":
            mc "Ти дивна жінка, Летті..."

            le "Мгм. Бачила забагато страждань. Це робить своє."

        "Може, і є.":
            mc "Може, і є. Спільного."

            le "Не поспішай з висновками. Але... може."

            $ add_chemistry("Летті", 2)

    jump lettie_r1c4_end

label lettie_r1c4_no_gods:
    show lettie at char_center

    mc "Ми не мали богів. Були Орокін — купка виродків, які вважали себе вищими за всіх."

    le "Не перший раз люди одягали корони і вважали себе божествами."

    le "І не останній. Розкажеш мені про них іншим разом. Маю роботу."

    $ add_chemistry("Летті", 2)
    $ add_insight("lettie_gods_interest", "Летті цікавлять боги та вірування. Хоче більше знати про Орокін.")

    jump lettie_r1c4_end

label lettie_r1c4_end:

    $ dialogue_end()
    $ store.seen_dialogues.add("lettie_rank1_convo4")
    $ set_flag("lettie_rank1_convo4_done")

    hide lettie
    return
