# game/dialogues/lettie/lettie_why_medic.rpy
# Летті розповідає, чому стала медиком — правда глибша за альтруїзм

init python:
    DIALOGUE_ENTRIES.append({
        "id": "lettie_why_medic",
        "who": "Летті",
        "conditions": {
            "flag_true": ["lettie_medical_ethics_done"],
            "flag_false": ["lettie_why_medic_done"],
            "rank_min": 2,
            "chemistry_min": ("Летті", 50),
        },
        "priority": 50,
        "chance": 100,
        "label": "lettie_why_medic",
    })

label lettie_why_medic:
    show lettie at char_center
    $ store.talked_today.add("Летті")

    le "Ти коли-небудь думав, чому я стала медиком?"
    $ advance_time(5)

    mc "Тому що хотіла допомагати людям?"
    $ advance_time(5)

    le "Ні. Це відповідь, яку дають на співбесідах. Справжня причина — огидніша."
    $ advance_time(5)

    le "Я хотіла зрозуміти, як речі ламаються. Тіла, системи, механізми. Мене завжди цікавило — де та точка, після якої все розпадається?"
    $ advance_time(5)

    mc "Це... не те, що я очікував."
    $ advance_time(5)

    le "Знаю. Я прийшла в медицину не з теплом у серці. Я прийшла з блокнотом і питанням — чому ця клітина відмирає, а та ні?"
    $ advance_time(5)

    le "Перший пацієнт, якого я лікувала по-справжньому — хлопець, років сімнадцять. Осколкове поранення. Він дивився на мене і казав: \"Скажи, що буде нормально.\""
    $ advance_time(5)

    menu:
        "І ти сказала?":
            $ advance_time(5)
            mc "І ти сказала?"
            le "Сказала. Збрехала. Він повірив. І знаєш що? Стало нормально. Він вижив."
            $ advance_time(5)
            le "Того дня я зрозуміла — знати, як речі ламаються, це половина справи. Друга половина — тримати когось за руку, поки складаєш їх назад."
            $ advance_time(5)

        "Коли ти почала піклуватись?":
            $ advance_time(5)
            mc "Коли ти почала піклуватись?"
            le "Коли перший пацієнт подивився мені в очі і я побачила, що він боїться більше за мене. Страх — заразний. Але спокій — теж."
            $ advance_time(5)
            le "Я навчилась бути спокійною не тому, що мені байдуже. А тому, що моє спокій — це єдині ліки, які я можу дати безкоштовно."
            $ advance_time(5)

    le "Тож ні, я не стала медиком через доброту. Я стала медиком через цікавість. А потім цікавість перетворилась на відповідальність."
    $ advance_time(5)

    le "І це гірше. Бо від цікавості можна відмовитись. Від відповідальності — ні."
    $ advance_time(5)

    $ store.seen_dialogues.add("lettie_why_medic")
    $ set_flag("lettie_why_medic_done")
    $ add_insight("lettie_medic_origin", "Летті стала медиком не через доброту а через цікавість до того як речі ламаються — потім почала піклуватись і це змінило все")

    hide letty
    return
