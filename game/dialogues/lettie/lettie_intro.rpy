# game/dialogues/lettie/lettie_intro.rpy
# ═══════════════════════════════════════════════════
# ЛЕТТІ — ІНТРО: Травми на місіях + щури + медвідділ
# ═══════════════════════════════════════════════════

init python:
    DIALOGUE_ENTRIES.append({
        "id": "lettie_intro",
        "who": "Летті",
        "conditions": {
            "flag_false": ["lettie_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Привіт, Летті.", "lettie_intro_main"),
        ],
    })


label lettie_intro_main:

    mc "Привіт, Летті."

    le "Ага."

    mc "..."

    le "Шо стоїш? Якщо прийшов — сідай. Якщо ні — не заважай."

    menu:
        "Сідаю.":
            mc "Сідаю."

            le "Ну от і добре."

            $ add_chemistry("Летті", 2)

        "Я на хвилинку.":
            mc "Я тільки на хвилинку."

            le "Тут всі «на хвилинку». А потім я їх зшиваю."

    le "Слухай, babas. Раз ти тут — давай одразу."

    le "Бачиш це?"

    # !!! ТУТ ПОКАЗАТИ МЕДВІДДІЛ — ліжка, інструменти, бинти !!!

    le "Це медвідділ. Мій медвідділ. Тут я лікую людей."

    le "І тебе, коли накосячиш на місії."

    mc "Коли?"

    le "Не «якщо». Коли. Повір."

    le "На місіях є шанс отримати травму. І ти, і напарник."

    le "Травми — це стаки. Один стак — подряпини. Два — серйозно. Три..."

    le "...три і ти лежиш тут, а я вирішую чи зможу тебе зібрати."

    menu:
        "Як уникнути травм?":
            mc "Є спосіб уникнути?"

            le "Si. Бери мене з собою."

            le "Коли я на місії — шанс травми нуль. Для всіх."

            mc "Серйозно?"

            le "Я не жартую про медицину, babas. Ніколи."

            $ add_chemistry("Летті", 4)
            $ add_insight("lettie_zero_injury", "Летті як напарник на місії = 0% шанс травми для всіх. Вона не жартує.")

        "А якщо вже поранився?":
            mc "А якщо вже отримав травму?"

            le "Приходь сюди. Я зніму один стак. Раз на день."

            le "Або чекай — стаки проходять самі через два дні. Якщо не додаш нових."

            $ add_chemistry("Летті", 2)
            $ add_insight("lettie_heals", "Летті знімає 1 стак травми на день. Або чекай 2 дні — пройде само.")

    le "І ще."

    le "Чим більше місій з одним напарником за день — тим вище шанс травми."

    le "Не перепрацьовуй людей. Вони не залізні."

    le "Ну... більшість не залізні."

    mc "А хто залізний?"

    le "Квінсі. Буквально. Але це не привід."

    $ add_chemistry("Летті", 2)

    le "А тепер..."

    le "Познайомся з Анітою."

    mc "З ким?"

    # Летті показує щура

    le "Аніта. Моя нова corazoncito."

    le "Вона ще маленька. Але вже з характером."

    menu:
        "Вона мила.":
            mc "Вона мила."

            le "Не кажи їй це. В неї зірковий синдром і так."

            $ add_chemistry("Летті", 4)

        "Ти тримаєш щура в медвідділі?":
            mc "Ти тримаєш щура в медвідділі? Поруч з пацієнтами?"

            le "Аніта стерильніша за більшість пацієнтів, babas."

            le "І точно приємніша."

            $ add_chemistry("Летті", 2)

        "В мене алергія.":
            mc "В мене алергія на щурів."

            le "Ні в тебе нема."

            mc "Звідки ти знаєш?"

            le "Я медик. Я знаю."

    $ store.seen_dialogues.add("lettie_intro")
    $ set_flag("lettie_intro_done")
    $ add_journal_entry("Летті — медик Гексу. Лікує травми, тримає щурів, не терпить дурнів. Аніта — її новий щур.", "event")
    $ add_insight("lettie_medic", "Летті — медик. Знімає стак травми раз на день. Летті на місії = 0% шанс травми.")
    $ add_insight("lettie_rats", "Летті тримає щурів. Аніта — нова. Маленька, з характером.")

    return
