# game/dialogues/quincy/quincy_rank1_convo3.rpy
# Квінсі — Ранг 1, Розмова 3: Звідки ти? Ідентичність і кухонна техніка

init python:
    DIALOGUE_ENTRIES.append({
        "id": "quincy_rank1_convo3",
        "who": "Квінсі",
        "conditions": {
            "flag_false": ["quincy_rank1_convo3_done"],
            "chemistry_min": ("Квінсі", 10),
        },
        "priority": 45,
        "chance": 100,
        "label": "quincy_rank1_convo3",
    })

label quincy_rank1_convo3:
    show quince at char_center
    $ store.talked_today.add("Квінсі")
    $ dialogue_begin()

    qu "Йо, ти тут?"

    menu:
        "О, дивись, Артур мене кличе. Бувай.":
            mc "Ой, здається Артур щось хоче. Пізніше!"
            qu "Lmao, ну біжи."
            jump quincy_r1c3_end_short

        "Звідки ти родом, Квінсі?":
            mc "Слухай, а звідки ти взагалі? Де виріс?"
            jump quincy_r1c3_main

        "Що привело тебе до Хьольванії?":
            mc "А що тебе взагалі занесло сюди, в Хьольванію?"
            jump quincy_r1c3_icr

    label quincy_r1c3_main:
    qu "А нащо питаєш? Ти б навіть на карті знайшов, якщо б я сказав? lol"

    menu:
        "Я... намагаюсь просто поговорити?":
            qu "Ну то тупо. Не треба."
            qu "Подивись на мене. Мене перетворили на якусь напівлюдину-напівкухонну-техніку."
            qu "А ти — якийсь космофрік із майбутнього."
            qu "«Розмови» — це для балачок у барах. Якщо ти не намагаєшся мене підкотити (і робиш це ОГИДНО)..."
            qu "То чого ти реально хочеш?"
            qu "Нащо тобі знати звідки я? Яка різниця?"
            jump quincy_r1c3_why

        "Я намагаюсь тебе пізнати і... не знаю з чого почати.":
            qu "Ок, чесність. Респект."
            qu "Я знаю що я — lux товар вищого ґатунку, навіть після того як мене перетворили на напівтостер."
            qu "Але мушу спитати — нащо?"

            menu:
                "Я не люблю грати в ігри, Квінсі.":
                    qu "Тоді ми на одній хвилі."
                    $ add_chemistry("Квінсі", 2)
                    jump quincy_r1c3_why

                "Вибач... що?":
                    qu "Чого ти реально хочеш?"
                    qu "Нащо тобі знати звідки я?"
                    jump quincy_r1c3_why

    label quincy_r1c3_why:

    menu:
        "Стоп, давай повернемось. *Кухонна техніка*?!":
            mc "Почекай-почекай. Кухонна техніка?!"
            qu "Lmao, ну подивись на мене, chief. Я виглядаю ніби моя мати зробила дитину з тостером."

            menu:
                "Що таке тостер?":
                    qu "О, m8... нам реально треба тебе підтягнути."
                    qu "Тобі потрібен гід, бо інакше засунеш фейс у блендер."

                    menu:
                        "А що таке *блендер*?":
                            qu "Бачиш?! Що й треба було доводити."
                            $ add_chemistry("Квінсі", 2)
                            jump quincy_r1c3_appliance_end

                        "Ну... бачу твою точку зору.":
                            jump quincy_r1c3_appliance_end

                "Ну, я вважаю що ти дуже сексуальний гібрид з тостером.":
                    qu "Damn straight, lololol."
                    qu "Не дуже паримось що ця хвороба зробила зі мною зовні, не буду брехати."
                    qu "У всього є свої плюси. Хоча тепер я реально боюсь що Аоі може зі мною зробити, lol."

                    menu:
                        "Аоі? Вона ж така мила.":
                            qu "Мила?! Ти її не бачив коли Артур на неї гавкає. Там такий погляд..."
                            qu "Думаєш Летті страшна? Чи Елеонор? Нааааа, fam."
                            qu "Не треба щоб вона мої деталі в орігамі перетворювала, ДЯКУЮ."
                            $ add_chemistry("Квінсі", 4)
                            $ add_insight("quincy_fears_aoi", "Квінсі жартома боїться Аоі — каже що її здібності можуть перетворити його металеві частини на орігамі.")
                            jump quincy_r1c3_patrol

                        "Да... миленькі — найнебезпечніші. А тепер ти ще й на 68% з металу.":
                            qu "Бачиш, ти мене розумієш."
                            qu "Іноді Артур гавкає на неї і в неї з'являється такий погляд, шіііт..."
                            qu "Думаєш Летті страшна? Елеонор? Нааа, fam."
                            qu "Не треба щоб вона з моїх запчастин паперових журавликів робила, ДЯКУЮ."
                            $ add_chemistry("Квінсі", 4)
                            $ add_insight("quincy_fears_aoi", "Квінсі жартома боїться Аоі — каже що її здібності можуть перетворити його металеві частини на орігамі.")
                            jump quincy_r1c3_patrol

        "Ти б не повірив, якщо б я розказав.":
            qu "Я бачив реально дикі речі за останній рік, m8."
            jump quincy_r1c3_deep

        "Я намагаюсь тебе зрозуміти і не знаю з чого починати.":
            jump quincy_r1c3_deep

    label quincy_r1c3_deep:

    menu:
        "Мені снились погані сни останнім часом. Про смерть.":
            qu "...Всім нам, cuz. Всім нам."
            jump quincy_r1c3_redirect

        "Ну... тобі, мабуть, краще не знати. Це...":
            qu "Знову космофрік-штучки з майбутнього?"

            menu:
                "Ні. Це... я відчуваю що ти знаєш, глибоко всередині. Це особисте. І неприємне.":
                    qu "Ага, можеш залишити це собі..."
                    qu "Бля, про що ти мене взагалі питав?!"

                    menu:
                        "Де ти виріс?":
                            qu "Ну от, тепер я вже не хочу про це говорити."
                            qu "Підніми це наступного разу. Фак."
                            jump quincy_r1c3_end_short

                "Космофрік-штучки з майбутнього. Я знаю що ти знаєш. І я намагаюсь це виправити.":
                    qu "...Ладно. Загадковий ти тип."
                    qu "Поговоримо про це пізніше."
                    jump quincy_r1c3_redirect

    label quincy_r1c3_redirect:
    qu "Ти хочеш знати хто я — спитай про те, що важливо ЗАРАЗ, розумієш?"
    qu "Не про якусь крапку на карті, яку ти б навіть не знайшов."

    menu:
        "Добре. У тебе залишилась сім'я вдома?":
            qu "Бачиш? Оце ти й намагався спитати з самого початку, без всієї тієї обгортки."

            menu:
                "Зрозумів.":
                    qu "Наступного разу, коли хочеш мене пізнати — переходь одразу до суті, ок?"
                    qu "Тільки тому що ми засіли в цьому тупому молі, не означає що я ціную базікання."
                    $ add_chemistry("Квінсі", 2)
                    $ add_insight("quincy_directness", "Квінсі цінує прямоту. Каже — не треба обгорток, питай одразу про суть.")
                    jump quincy_r1c3_end

        "Є щось, чим ти готовий поділитись?":
            qu "Хз. Розкажи мені щось серйозне про себе — тоді я розкажу щось про себе."
            qu "Але це вже наступного разу. Мені пора."
            $ add_chemistry("Квінсі", 2)
            jump quincy_r1c3_end

    jump quincy_r1c3_end

    label quincy_r1c3_appliance_end:
    qu "Коротше. Ти — тостер без інструкції. Я — напівтостер з досвідом. Думаю, ми зрозуміли одне одного."
    $ add_chemistry("Квінсі", 2)
    jump quincy_r1c3_end

    label quincy_r1c3_patrol:
    qu "І на цій прекрасній ноті — я лінять."
    qu "Коли про вовка мовиш — геройбой пейджить мене як скажений на патруль. l8r."
    $ add_chemistry("Квінсі", 2)
    jump quincy_r1c3_end

    label quincy_r1c3_end:

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo3")
    $ set_flag("quincy_rank1_convo3_done")

    hide quince
    return

    label quincy_r1c3_end_short:

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo3")
    $ set_flag("quincy_rank1_convo3_done")

    hide quince
    return
