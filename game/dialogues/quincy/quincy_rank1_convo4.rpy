# game/dialogues/quincy/quincy_rank1_convo4.rpy
# Квінсі — Ранг 1, Розмова 4: Обмін "жорсткими" історіями — минуле Квінсі

init python:
    DIALOGUE_ENTRIES.append({
        "id": "quincy_rank1_convo4",
        "who": "Квінсі",
        "conditions": {
            "flag_false": ["quincy_rank1_convo4_done"],
            "chemistry_min": ("Квінсі", 18),
        },
        "priority": 45,
        "chance": 100,
        "titles": [
            ("Ой, вибач, пізніше!", "quincy_r1c4_end_short"),
            ("Що як, Q?", "quincy_r1c4_main"),
        ],
    })

    label quincy_r1c4_main:
    show quince at char_center

    qu "Бачу як ти нюхаєш навколо екіпажу, намагаєшся зрозуміти де ти серед нас всіх стоїш."
    qu "Тож я вирішив полегшити тобі задачу і розпочати першим, ок?"
    qu "Давай серйозну тему. Розкажи мені щось жорстке про себе — і я розкажу щось про себе."

    menu:
        "У тебе все — обмін?":
            qu "Lmao. Ну да. Погана звичка. Важко зламати."
            qu "Але серйозно — розкажи. Щось реальне."
            jump quincy_r1c4_share

        "Я б розказав, якби знав що означає «жорстке» в твоєму контексті.":
            qu "Ну да, я так роблю, сорі m8. Означає — серйозне. Розкажи щось важке."
            jump quincy_r1c4_share

    label quincy_r1c4_share:

    menu:
        "Я втік з особистого пекла тільки щоб потрапити в систему, де всесвіт захопив маніяк.":
            mc "Я втік з особистого пекла тільки щоб потрапити в систему, де всесвіт захопив божевільний тиран."
            mc "Мені довелося боротися, переважно самому, щоб звільнити промитих невинних і повстати проти двох фанатиків при владі."
            mc "Один з яких — брат тієї сутності, що врятувала мені життя. Зрештою... ми перемогли. Але я досі пам'ятаю той жах."

            menu:
                "Досить «жорстко»?":
                    jump quincy_r1c4_react

        "Мене утримували незліченні століття в нескінченно повторюваному вимірі, де мене катували і вбивали.":
            mc "Мене утримували безліч століть у вимірі, що нескінченно повторюється. Там мене катував і вбивав дитячий деспот."
            mc "Який, між іншим, був створений з моїх власних спогадів, коли Безодня залізла мені в голову і витягла фрагменти казкової книжки."

            menu:
                "Досить «жорстко»?":
                    jump quincy_r1c4_react

        "Єдине місце, яке я знав як дім — напівзруйнований корабель, застряглий у щілині між вимірами.":
            mc "Єдине місце, яке я знав як дім — це зруйнований корабель, що застряг як корок у щілині між реальностями."
            mc "Там жили привиди і жахливі спогади. Там я вперше зустрів Байдужість."
            mc "Там Людина у Стіні забрала у мене ВСЕ."
            jump quincy_r1c4_wall_react

    label quincy_r1c4_react:
    qu "Я... ага."
    qu "Holy shit, cuz. Ти настільки повний космічної травми, що це могло б бути твоїм ім'ям."
    qu "І ця фігня далеко за межами «жорсткого». Це просто bare mental."
    qu "Невдивно що ти прийняв весь цей булшіт тут як щось звичне."

    menu:
        "Це точно не найдивніше і не найгірше, з чим я мав справу.":
            jump quincy_r1c4_quincy_share

        "Додай до купи «космічної травми», як кажуть.":
            jump quincy_r1c4_quincy_share

    label quincy_r1c4_wall_react:
    qu "Стоп, шо, ти маєш біф з БОГОМ?! Fking hell."
    qu "Тобі треба буде мені все розказати наступного разу."
    qu "Але якщо тобі було вибирати між тим місцем і цим..."
    qu "Принаймні в цій діркі є мій lux зад, який підвищує клас закладу, lmao."
    qu "І хоча б ти за собою прибираєш. Фак. Хтось навчіть Аміра куди сміття класти. Брудень привабить ще більше тваринок для Летті."

    menu:
        "Хтось повинен залишитись, щоб тримати тебе в покорі.":
            qu "Lmao. Good luck with that, cuz."
            $ add_chemistry("Квінсі", 4)
            jump quincy_r1c4_home_hint

        "Це ти так кажеш, що я тут свій?":
            qu "Не буду тобі це розжовувати, тунелю. lol. Подумай добре — дійдеш."
            $ add_chemistry("Квінсі", 4)
            $ add_insight("quincy_welcome", "Квінсі по-своєму дав зрозуміти, що я тут свій. Не прямо — але чесно.")
            jump quincy_r1c4_end

    label quincy_r1c4_home_hint:
    qu "Ладно, давай і я скину."
    jump quincy_r1c4_quincy_share

    label quincy_r1c4_quincy_share:
    qu "Fking серйозно, m8. Респект де респект заслужено. І я знаю ми тільки почали."
    qu "Тож ось що тобі треба знати, щоб зрозуміти твого єдиного Квінсі-К."
    qu "Я виріс жорстко, розумієш? Бився за все що приносив додому бабусі й сестрі. Зубами і нігтями."
    qu "Бо все, що ти сам не візьмеш — хтось інший забере."
    qu "Треба крутитися, щоб протягнути до кінця дня, якщо хочеш вижити."

    menu:
        "Я не жив таким життям... але я тебе розумію. І поважаю.":
            mc "Я не жив таким життям. Але розумію тебе. І поважаю це."

            menu:
                "Треба бути сильною людиною, щоб робити це день за днем.":
                    qu "Гарно що розпізнаєш це, навіть якщо сам не жив так, cuz. Це показує справжню мудрість."
                    $ add_chemistry("Квінсі", 4)
                    $ add_insight("quincy_upbringing", "Квінсі виріс у бідності, бився за кожну копійку для бабусі й сестри. Він цінує коли це визнають без жалю.")
                    jump quincy_r1c4_outro

                "Але я також думаю, що в тобі є більше ніж просто хлопець, який крутиться щоб вижити.":
                    qu "Може так. Може ні. Тримайся достатньо довго — може дізнаєшся. А може й ні."
                    qu "Але гарно що поважаєш те, чого не знаєш."
                    $ add_chemistry("Квінсі", 4)
                    $ add_insight("quincy_upbringing", "Квінсі виріс у бідності, тримав сім'ю на плаву. Натякнув що в ньому є щось більше під поверхнею.")
                    jump quincy_r1c4_outro

        "Хотів би сказати що в майбутньому стало краще. Але ні. Все те саме.":
            mc "Хотів би сказати що в майбутньому стало краще. Теж бував у таких ситуаціях."
            mc "Все стало складніше, але базові проблеми ті ж. Люди — все ще люди."
            qu "Реально надіявся що майбутнє не буде купою лайна, cuz. Шкода що твоє минуле не сильно відрізняється від мого."
            qu "Обміняємось ще лайняними історіями пізніше, га?"
            $ add_chemistry("Квінсі", 4)
            $ add_insight("quincy_upbringing", "Квінсі виріс у бідності, крутився заради сім'ї. Ми знайшли спільне — обидва знаємо що таке боротьба за виживання.")
            jump quincy_r1c4_outro

        "Я не сповідую філософію «переможець забирає все». Має бути щось більше у житті.":
            qu "Так кажуть ті, кому не треба крутитися. Ми крутимось щоб МАТИ те «більше». Дивись зверху скільки хочеш."
            qu "Але коли в тебе нічого крім крихт — робиш що мусиш."
            qu "Я знаю що ти не місцевий і в тебе свої проблеми. Тому зроблю знижку."
            qu "Але розумій — є речі, про які ти навіть не здогадуєшся, chief."
            $ add_chemistry("Квінсі", 2)
            jump quincy_r1c4_end

    label quincy_r1c4_outro:
    qu "Все, мені пора. Час стріляти скалдру."

    menu:
        "Розважайся.":
            qu "Fking oodles."

        "Бережи себе.":
            qu "Lol. Їм до мене далеко, cuz. Ти ж знаєш."
            $ add_chemistry("Квінсі", 2)

    label quincy_r1c4_end:

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo4")
    $ set_flag("quincy_rank1_convo4_done")
    $ set_flag("quincy_rank1_complete")

    hide quince
    return

    label quincy_r1c4_end_short:
    show quince at char_center

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo4")
    $ set_flag("quincy_rank1_convo4_done")
    $ set_flag("quincy_rank1_complete")

    hide quince
    return
