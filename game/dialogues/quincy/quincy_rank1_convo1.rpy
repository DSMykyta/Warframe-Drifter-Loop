# game/dialogues/quincy/quincy_rank1_convo1.rpy
# Квінсі — Ранг 1, Розмова 1: "Йо" — перший справжній контакт

init python:
    DIALOGUE_ENTRIES.append({
        "id": "quincy_rank1_convo1",
        "who": "Квінсі",
        "conditions": {
            "flag_false": ["quincy_rank1_convo1_done"],
            "chemistry_min": ("Квінсі", 0),
        },
        "priority": 50,
        "chance": 100,
        "titles": [
            ("Сорі, зараз зайнятий.", "quincy_r1c1_end_short"),
            ("Привіт. Ти хтось із Гексу?", "quincy_r1c1_muppet"),
            ("Йо.", "quincy_r1c1_space"),
        ],
    })

    label quincy_r1c1_muppet:
    show quince at char_center

    qu "Ти шо, тунель? lol. Ну да, це я перевіряю чи ти живий."

    menu:
        "Я... не дуже шарю у місцевому сленгу. Я ж із майбутнього, пам'ятаєш?":
            qu "Да-да, космофрік. Тримайся мене — швидко розберешся."
            jump quincy_r1c1_space

        "Можеш пояснити нормально? Чим допомогти?":
            qu "Тримайся мене, m8, я тобі все покажу. ;)"
            jump quincy_r1c1_space

    label quincy_r1c1_space:
    show quince at char_center

    qu "Коротше, я ось чого хотів."
    qu "Ти ж із космосу. Типу... КОСМОСУ-космосу."

    menu:
        "На відміну від некосмічного космосу?":
            qu "РОФЛ, ладно, fair enough."
            qu "Не буду брехати — складно це все вмістити в голові."
            jump quincy_r1c1_future

        "Ну, технічно я спочатку із Землі.":
            qu "Шііііт, стоп. Швиденько — я відомий у майбутньому? Мушу знати."

            menu:
                "Ага, звісно. Тобі скрізь пам'ятники стоять.":
                    qu "...Ти шо, думаєш я тупий? Я бачу коли мені брешуть, m8."
                    qu "Тільки тому що я тепер вічний, не означає що можна витрачати мій час."
                    jump quincy_r1c1_end_short

                "Навряд чи, сорі.":
                    qu "Ну от, шкода. Продовжуй."
                    jump quincy_r1c1_future

                "Може й був якийсь час. Але я з ДУЖЕ далекого майбутнього.":
                    qu "Наскільки далекого?"
                    jump quincy_r1c1_how_far

        "По суті — так.":
            qu "Це просто fking ЖЕСТЬ, lol."
            qu "Не буду брехати — складно це все вкурити."
            qu "Ти не тільки з космосу, а ще й з майбутнього."
            jump quincy_r1c1_how_far

    label quincy_r1c1_future:
    qu "Ти не просто з космосу — ти ще й з майбутнього."

    label quincy_r1c1_how_far:
    qu "Наскільки далекого майбутнього ми говоримо?"

    menu:
        "Твоя здогадка не гірша за мою.":
            qu "Окей. Не хочеш зі мною базарити? Не буду тиснути."
            qu "Але я бачу коли хтось щось приховує, chief."
            jump quincy_r1c1_sitch

        "Поняття не маю. Орокін знищили всі записи про стародавню Землю.":
            qu "Це якийсь next level. Хто такі Орокін?"

            menu:
                "Це... довга історія. Що ти хотів обговорити?":
                    jump quincy_r1c1_sitch

                "Мудаки, які вважали себе богами і поводилися відповідно.":
                    qu "Ну, чим більше все змінюється, тим більше все залишається по-старому, да? Розчаровує."
                    jump quincy_r1c1_sitch

    label quincy_r1c1_sitch:
    qu "Коротше, ситуація така."
    qu "Ти тут новенький. А я вже два роки тут тру, вивчив місцевість і заслужив довіру людей на землі."

    menu:
        "Я... не зовсім розумію до чого ти ведеш.":
            qu "Сміливо, що чесно кажеш. Респект. Будеш так тримати — здружимось швидко."
            jump quincy_r1c1_offer

        "Ти мені погрожуєш?":
            qu "Ти шо, серйозно? lol. Ні, дурню."
            jump quincy_r1c1_offer

        "Здається, розумію...":
            qu "Давай я на всяк випадок поясню, ок?"
            jump quincy_r1c1_offer

    label quincy_r1c1_offer:
    qu "Кажу ось що: тобі треба гіда в цьому часі, космофріку."
    qu "І я пропоную взяти тебе під крило."

    menu:
        "Вибач, поки я намагаюсь ДУЖЕ не засміятися.":
            qu "Та сміх смішком, але давай серйозно."
            jump quincy_r1c1_warzone

        "Навчити мене... як існувати в цьому часі?":
            jump quincy_r1c1_warzone

    label quincy_r1c1_warzone:
    qu "Ти коли-небудь був у зоні бойових дій типу цієї? Коли цивільні борються за свої домівки, просто щоб вижити?"

    menu:
        "Технологія — ну, точніше, її відсутність — трохи збиває з пантелику.":
            qu "О, це тільки початок, m8."
            jump quincy_r1c1_deal

        "Якщо чесно... так. І це було жахливо.":
            qu "Ти був на війні, космофріку? Серйозно?"
            qu "Ок, ок... до цього ми ще дійдемо."
            jump quincy_r1c1_deal

        "Схоже, але інакше. Усі зони бойових дій — відстій.":
            qu "Ти був на війні, космофріку? Сєрьозно?"
            qu "Ок, ок... до цього ще дійдемо."
            jump quincy_r1c1_deal

    label quincy_r1c1_deal:
    qu "Але я бачу як ти намагаєшся махати рукою перед телеком ніби це якийсь детектор руху, lol."
    qu "Тобі потрібен гід, chief. Бо інакше засунеш обличчя в тостер, якщо не будеш обережний."

    menu:
        "Що таке тостер?":
            qu "Бачиш?! Підтверджую свою думку."
            jump quincy_r1c1_exchange

        "Ну... бачу твою точку зору.":
            jump quincy_r1c1_exchange

    label quincy_r1c1_exchange:
    qu "Отже. Ти допомагаєш мені, я допомагаю тобі. Ідеть?"

    menu:
        "Ні. Пас. Я на тебе не працюю, Квінсі.":
            mc "Ні, сорі. Я не підписувався бути чиїмось підлеглим."
            qu "Ну ок. Не наполягаю. Поки що."
            $ add_chemistry("Квінсі", 2)
            jump quincy_r1c1_end

        "Я так і знав, що буде ціна.":
            qu "Та просто маленька послуга. Нічого серйозного. Обіцяю."

            menu:
                "...Добре. Але щоб я не пошкодував.":
                    qu "БУУУМ, от це розмова, cuz!"
                    qu "Дам знати коли знадобиться та послуга."
                    $ add_chemistry("Квінсі", 4)
                    $ set_flag("quincy_favor_owed")
                    jump quincy_r1c1_end

                "Ні. Пас.":
                    mc "Ні, без умов."
                    qu "Ну ок, gg. Побачимо."
                    $ add_chemistry("Квінсі", 2)
                    jump quincy_r1c1_end

        "Що ти хочеш натомість?":
            qu "Хммм, tbd. Послугу. Нічого великого. Обіцяю."

            menu:
                "...Добре. Але не змушуй мене шкодувати.":
                    qu "БУУУМ, от це базар, cuz! Тепер говоримо!"
                    qu "Дам знати коли потрібна буде послуга."
                    $ add_chemistry("Квінсі", 4)
                    $ set_flag("quincy_favor_owed")
                    jump quincy_r1c1_end

                "Ні. Пас.":
                    mc "Без умов — не підписуюсь."
                    qu "Fair enough. Без образ."
                    $ add_chemistry("Квінсі", 2)
                    jump quincy_r1c1_end

    label quincy_r1c1_end:

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo1")
    $ set_flag("quincy_rank1_convo1_done")
    $ add_insight("quincy_guide_offer", "Квінсі запропонував стати моїм гідом у цьому часі. Він тут вже два роки і знає місцевість.")

    hide quince
    return

    label quincy_r1c1_end_short:
    show quince at char_center

    $ dialogue_end()
    $ store.seen_dialogues.add("quincy_rank1_convo1")
    $ set_flag("quincy_rank1_convo1_done")

    hide quince
    return
