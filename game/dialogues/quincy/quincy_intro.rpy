# game/dialogues/quincy/quincy_intro.rpy
# ═══════════════════════════════════════════════════
# КВІНСІ — ІНТРО: Скальдра, Русалка, Віктор + підстава з "бро"
# ═══════════════════════════════════════════════════

init python:
    DIALOGUE_ENTRIES.append({
        "id": "quincy_intro",
        "who": "Квінсі",
        "conditions": {
            "flag_false": ["quincy_intro_done"],
        },
        "priority": 90,
        "chance": 100,
        "titles": [
            ("Привіт.", "quincy_intro_main"),
        ],
    })


label quincy_intro_main:

    mc "Привіт."

    qu "Привіт? Серйозно?"

    qu "В майбутньому весь сленг вимер чи шо?"

    menu:
        "В мене були інші пріоритети, ніж сленг.":
            mc "В мене були інші пріоритети, ніж сленг."

            qu "Fair enough. Але тут тобі доведеться підтягнутись, cuz."

            $ add_chemistry("Квінсі", 2)

        "А як треба було сказати?":
            mc "А як треба було сказати?"

            qu "Та шо завгодно окрім «привіт» як бабуся до сусідки."

            qu "Ладно, прощаю. Ти з іншого часу."

        "Йо.":
            mc "Йо."

            qu "О! Бачиш, вмієш коли хочеш!"

            $ add_chemistry("Квінсі", 4)

    qu "Короче, Марті. Раз ти тут — маєш знати базу."

    mc "Слухаю."

    qu "За стінами молу — місто. Гьольванія."

    qu "Було класне місце. Бари, музика, люди. А тепер..."

    qu "Скальдра. Чув про них?"

    menu:
        "Ні. Що це?":
            mc "Ні. Що це?"

            qu "Заражені. Техногниль перетворює людей на... щось інше."

            qu "Вони не зовсім мертві, не зовсім живі. Просто... злі. І швидкі."

            qu "Раніше вони були сусідами, продавцями, друзями. Тепер — targets."

            $ add_insight("scaldra_basics", "Скальдра — люди, заражені Техногниллю. Агресивні, швидкі, колишні мешканці Гьольванії.")

        "Щось чув від Артура.":
            mc "Щось чув. Заражені?"

            qu "Заражені — це м'яко сказано. Вони тебе зжеруть якщо зазіваєшся."

            $ add_insight("scaldra_basics", "Скальдра — заражені Техногниллю. Небезпечні.")

    qu "А ще — Русалка."

    mc "Русалка?"

    qu "Жінка. Якщо це слово ще підходить."

    qu "Контролює скальдру. Або вони контролюють її. Ніхто не знає точно."

    qu "Живе десь у глибині міста. Ми її бачили пару разів. Краще б не бачили."

    $ add_insight("rusalka_exists", "Русалка — хтось або щось, пов'язане зі скальдрою. Контролює їх.")

    mc "А Віктор?"

    qu "О, Віктора ти ще зустрінеш."

    qu "Лікар. Або був лікарем. Зараз він... складний."

    qu "Допомагає місцевим. Але в нього свої методи. І свої секрети."

    qu "Артур йому не довіряє. Елеонор вважає його цікавим. Летті його ненавидить."

    qu "Я? Я просто тримаю його на мушці коли він поряд. На всяк випадок."

    $ add_chemistry("Квінсі", 2)
    $ add_insight("viktor_doctor", "Віктор — лікар в Гьольванії. Артур не довіряє, Летті ненавидить. Квінсі тримає на мушці.")

    menu:
        "Дякую за інформацію. Корисно.":
            mc "Дякую. Тепер хоч розумію де я опинився."

            qu "Не дякуй. Тут всі мають знати правила гри."

        "Весела компанія зібралась.":
            mc "Весела компанія зібралась."

            qu "Lmao. Ти ще й половини не бачив, m8."

            $ add_chemistry("Квінсі", 2)

    # ═══ Підстава з "бро" — тільки якщо НЕ був у Артура ═══
    if not store.flags.get("arthur_intro_done"):

        qu "О, і ще."

        qu "Ти ж ще не говорив з героєбоєм?"

        mc "З ким?"

        qu "З Артуром. Нашим великим лідером."

        qu "Маленька порада, cuz. Він любить коли до нього звертаються по-свійськи."

        qu "Типу «бро». Або «братан». Він тоді відразу розслабляється."

        qu "Trust me on this one."

        menu:
            "Серйозно? Не схоже на нього.":
                mc "Серйозно? Він виглядає як людина, яка НЕ любить «бро»."

                qu "Ні-ні, це маска. Всередині він м'який як пончик."

                qu "Спробуй. Що ти втрачаєш?"

                $ set_flag("quincy_told_bro")

            "Окей, спробую.":
                mc "Добре. Спробую."

                qu "Gg. Скажеш мені потім як пройшло."

                $ set_flag("quincy_told_bro")
                $ add_chemistry("Квінсі", 2)

            "Щось мені підказує що це погана ідея.":
                mc "Щось мені підказує що це погана ідея."

                qu "Ти розумніший ніж виглядаєш, Марті."

                $ add_chemistry("Квінсі", 4)
                $ add_insight("quincy_prankster", "Квінсі спробував підставити мене з Артуром. Але я не повівся.")

    $ store.seen_dialogues.add("quincy_intro")
    $ set_flag("quincy_intro_done")
    $ add_journal_entry("Квінсі розповів про скальдру, Русалку і Віктора. Базова картина загроз.", "lore")

    return
