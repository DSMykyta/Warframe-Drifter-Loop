# ═══════════════════════════════════════════════════
# ДЕМО: Бонусна опція — вклинюється в БУДЬ-ЯКЕ меню NPC
# ═══════════════════════════════════════════════════
# Бонусна опція з'являється в меню взаємодії з NPC
# поруч зі звичайними titles діалогу, подарунком і "незважай".
#
# КЛЮЧОВА МЕХАНІКА: якщо бонусна опція ПОКАЗАЛАСЬ в меню —
# вона зникає назавжди. Обрали чи ні — не важливо.
# Побачив = зіграв.
#
# Приклади: "Хай, бро" (підстава від Квінсі),
# "Та куртка з метро!" (коментар про одяг NPC).

init python:
    BONUS_OPTIONS.append({
        "id": "demo_bonus_jacket",
        "who": "Артур",
        "text": "Гарна куртка. Нова?",             # текст в меню
        "label": "demo_bonus_jacket_react",         # label для call
        "conditions": {
            "flag_true": ["demo_arthur_has_jacket"], # з'являється тільки з прапором
        },
        # "outfit_check": ("Артур", "metro_jacket"),  # !!! КОЛИ CLOTHING ГОТОВИЙ
        "once": True,                                # зникає після показу
    })


label demo_bonus_jacket_react:
    # Ця гілка викликається через call — після return повертається в location_loop
    ar "Що?"

    mc "Куртка. Нова?"

    ar "...Може."

    menu:
        "Тобі йде.":
            ar "Дякую."
            $ add_chemistry("Артур", 4)

        "Вона ж була в смітті.":
            ar "На ЛАВЦІ. Це різні речі."
            $ add_chemistry("Артур", 2)

    # mark_bonus_used — НЕ ПОТРІБНО! location_loop робить це автоматично
    # при показі меню (всі once=True бонуси маркуються при відображенні)
    return
