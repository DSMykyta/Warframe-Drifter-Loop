# ═══════════════════════════════════════════════════
# ДЕМО: Forced діалог — NPC ініціює розмову
# ═══════════════════════════════════════════════════
# Гравець заходить в локацію → NPC автоматично починає говорити.
# Без меню titles — діалог починається одразу.
# Гравець НЕ обирає початок — NPC говорить першим.
#
# Використовується для: інтро NPC, важливих подій, перехоплень.
# Приклад: Аоі інтро — вона сама підходить і питає про On-lyne.

init python:
    DIALOGUE_ENTRIES.append({
        "id": "demo_forced_dialogue",
        "who": "Аоі",
        "conditions": {
            "flag_false": ["demo_forced_dialogue_done"],
            "chemistry_min": ("Аоі", 20),
        },
        "priority": 80,         # вище за звичайні — forced має пріоритет
        "chance": 100,
        "forced": True,         # ← КЛЮЧОВЕ — NPC ініціює
        "label": "demo_forced_dialogue",   # label а НЕ titles (одна точка входу)
    })


label demo_forced_dialogue:
    # NPC говорить ПЕРШИМ — без mc на початку
    ao "Ей! Зачекай!"

    ao "Я тут дещо знайшла. Подивись."

    menu:
        "Що це?":
            mc "Що це?"
            ao "Не знаю, але виглядає цікаво."
            $ add_chemistry("Аоі", 2)

        "Зараз зайнятий.":
            mc "Вибач, зараз зайнятий."
            ao "Ну добре... потім покажу."

    return
