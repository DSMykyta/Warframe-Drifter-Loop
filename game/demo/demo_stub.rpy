# ═══════════════════════════════════════════════════
# ДЕМО: Stub — заглушка коли нема eligible діалогів
# ═══════════════════════════════════════════════════
# Стаби — короткі фрази для ситуацій коли всі діалоги
# вичерпані або не підходять за умовами.
# НЕ реєструються в DIALOGUE_ENTRIES — диспетчер
# автоматично дає stub через get_stub().
#
# Теми визначені в STUB_TOPICS (dispatcher.rpy).
# Label = stub_{Ім'я}_{тема} або stub_{Ім'я}_{тема}_{локація}_{стан}
#
# Стан гравця (get_player_state()):
#   "tired"    — після 23:00
#   "stressed" — 3+ днів без місій
#   "normal"   — все інше
#
# Приклади (реальні label в game/stubs/):
#   label stub_Артур_cooking:
#   label stub_Артур_cooking_bar_tired:
#   label stub_Квінсі_boredom:
