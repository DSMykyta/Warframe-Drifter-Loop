# game/events/missions/metro_jacket_event.rpy
# ═══════════════════════════════════════════════════════════════
# МІСІЙНИЙ ІВЕНТ: Куртка на станції метро
# ═══════════════════════════════════════════════════════════════
# Умови: Аоі і Артур на місії, rank 3+, chemistry 30+ з обома.
# Після бою з техногниллю на станції метро — Аоі знаходить куртку.
# Гравець вибирає: забрати собі або залишити.
# Якщо залишити — Артур тихо забере (флаг + одяг в пул).

init python:
    MISSION_DIALOGUE_ENTRIES.append({
        "id": "metro_jacket_event",
        "who": "Артур",
        "conditions": {
            "flag_false": ["metro_jacket_event_done"],
            "chemistry_min": ("Артур", 30),
            "rank_min": 3,
        },
        "priority": 60,
        "chance": 75,
        "label": "metro_jacket_event",
    })


label metro_jacket_event:
    # Сцена: станція метро після зачистки

    ao "Зачекайте."
    ao "Там на лавці... бачите?"

    ar "Аоі, ми на місії."

    ao "Та зачекай ти! Подивись — куртка. Ціла. Навіть чиста."

    mc "Серед техногнилі? Дивно."

    ao "Шкіряна. І виглядає... непогано, насправді."

    ar "Це сміття. Можемо рухатись далі?"

    ao "Це НЕ сміття, Артуре. Це вінтаж."

    ar "Вінтаж. На зараженій станції метро."

    ao "Найкращі знахідки — в найгірших місцях!"

    mc "Вона має рацію, знаєш."

    ar "..."

    menu:
        "Заберу собі. Непогана куртка.":
            mc "Я візьму її. Мені якраз не завадить."

            ao "О! Тобі точно піде!"

            ar "Як хочеш. Рухаємось."

            $ set_flag("drifter_has_metro_jacket")
            $ add_chemistry("Аоі", 2)
            $ add_insight("metro_jacket_found", "Знайшли куртку на зараженій станції метро. Аоі вважає це знахідкою.")

        "Та ні, залиш. Невідомо що на ній.":
            mc "Краще не ризикувати. Хтозна що на ній може бути."

            ao "Ех... Ти правий, напевно."

            ar "Розумне рішення."

            # Артур тихо забере — гравець цього не бачить
            $ set_flag("arthur_has_metro_jacket")
            $ add_chemistry("Артур", 2)
            $ add_insight("metro_jacket_found", "Знайшли куртку на станції метро. Я відмовився — хтозна що на ній.")

        "Артуре, може тобі? Виглядає в твоєму стилі.":
            mc "Знаєш, Артуре... ця куртка — вона прям твоя."

            ar "Моя? Я не збираю речі з..."

            ao "Артуре. Подивись на неї. Серйозно."

            ar "..."

            ar "...Добре. Але тільки тому що Аоі не замовкне."

            ao "Він її взяв! Перемога!"

            $ set_flag("arthur_has_metro_jacket")
            $ set_flag("arthur_took_jacket_openly")
            $ add_chemistry("Артур", 4)
            $ add_chemistry("Аоі", 2)
            $ add_insight("metro_jacket_arthur", "Артур взяв куртку з метро. Казав що не хоче, але Аоі переконала.")

    ao "Гарна місія."
    ar "Рухаємось."

    $ store.seen_dialogues.add("metro_jacket_event")
    $ set_flag("metro_jacket_event_done")
    return


# ═══════════════════════════════════════════════════════════════
# БОНУСНА ОПЦІЯ: Коментар про куртку коли Артур її одягне
# ═══════════════════════════════════════════════════════════════
# З'являється В БУДЬ-ЯКОМУ діалозі з Артуром коли:
# 1. Артур має куртку (flag)
# 2. Артур одягнений в metro_jacket (outfit_check)
#
# !!! КОЛИ CLOTHING.RPY ПОВНІСТЮ ГОТОВИЙ — РОЗКОМЕНТУВАТИ outfit_check !!!

init python:
    BONUS_OPTIONS.append({
        "id": "arthur_metro_jacket_comment",
        "who": "Артур",
        "text": "О! Зачекай, це що та куртка з метро?",
        "label": "arthur_metro_jacket_react",
        "conditions": {
            "flag_true": ["arthur_has_metro_jacket"],
        },
        # !!! РОЗКОМЕНТУВАТИ КОЛИ CLOTHING.RPY ПРАЦЮЄ:
        # "outfit_check": ("Артур", "metro_jacket"),
        "once": True,
    })


label arthur_metro_jacket_react:
    # Ця гілка викликається через call з будь-якого діалогу з Артуром

    ar "Що?"

    mc "Куртка. Та, зі станції метро."

    if store.flags.get("arthur_took_jacket_openly"):
        # Він взяв відкрито при Аоі
        ar "Аоі мене переконала. Що тут такого."

        menu:
            "Тобі йде. Серйозно.":
                ar "..."
                ar "Дякую."
                $ add_chemistry("Артур", 4)

            "Аоі була права — вінтаж тобі пасує.":
                ar "Скажи їй це, і вона не замовкне тиждень."
                ar "Але... так. Може вона не зовсім помилилась."
                $ add_chemistry("Артур", 2)
                $ add_chemistry("Аоі", 2)

    else:
        # Він забрав тишком (гравець відмовився)
        ar "..."

        ar "Я подумав... що було б дурно залишити добру річ."

        menu:
            "Тобто ти її забрав після того як я відмовився?":
                ar "Можеш сміятися."

                menu:
                    "Не буду. Тобі реально йде.":
                        ar "..."
                        ar "Дякую."
                        $ add_chemistry("Артур", 4)
                        $ add_insight("arthur_metro_jacket_secret", "Артур тихо забрав куртку з метро після того як я відмовився. Йому соромно, але вона йому йде.")

                    "Ха! Я знав що ти її візьмеш!":
                        ar "Ти... знав?"
                        mc "Ти так подивився на неї. Було очевидно."
                        ar "Чорт. Я настільки передбачуваний?"
                        $ add_chemistry("Артур", 2)

            "Я радий що ти її взяв.":
                ar "Правда?"
                mc "Аоі була права. Вона твоя."
                ar "...Може ти маєш рацію."
                $ add_chemistry("Артур", 4)

    $ mark_bonus_used("arthur_metro_jacket_comment")
    $ add_journal_entry("Побачив Артура в тій куртці з метро. Йому йде.", "conversation")
    return
