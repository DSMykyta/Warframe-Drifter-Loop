# game/scenes/explore_mall.rpy
# ═══════════════════════════════════════════════════
# СЦЕНА 2: Дрифтер досліджує мол, знаходить карту
# ═══════════════════════════════════════════════════
# Після інтро, перший ранок. Дрифтер виходить з бекруму.
# Петля 1: повне дослідження, здивування, знахідка карти.
# Петля 2+: швидке — "десь тут була карта", знаходить, готовий.

label explore_mall:

    scene bg_mall with dissolve

    if not is_loop_restart():
        # ═══ ПЕРША ПЕТЛЯ: Повне дослідження ═══

        "..."

        "Нічого собі."

        "Це мол. Величезний, тихий, порожній мол."

        "Десь грає музика. Тихо. З динаміків під стелею."

        "Вивіски. Магазини. Ескалатори. Все як у... нормальному світі?"

        "Тільки нормальних людей тут не залишилось."

        "Ладно. Треба зорієнтуватись."

        # Перехід до інфостійки
        play sound "audio/sfx_footsteps.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!
        pause 1.0

        scene bg_info_desk with dissolve

        "Інфо-острівець. Стійка з брошурами, схемами евакуації, і..."

        play sound "audio/sfx_papers.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!
        pause 0.5

        "О!"

        play sound "audio/sfx_paper_grab.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!

        "Карта. План молу. Цілий, читабельний."

        "Чірік."

        # Карта тепер доступна
        $ set_flag("has_map")

        "Тепер хоча б не заблукаю."

        "Так... бекрум десь позаду. Тир, аркади, медвідділ — все по периметру."

        "Гараж — через комп'ютерний клуб. Дах — сходи з центру."

        "Окей. Можна жити."

    else:
        # ═══ ПОВТОРНА ПЕТЛЯ: Швидке дослідження ═══

        "Мол. Знову."

        "Карта... десь тут же мала бути."

        play sound "audio/sfx_footsteps.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!
        pause 0.8

        scene bg_info_desk with dissolve

        play sound "audio/sfx_papers.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!
        pause 0.3

        "Є."

        $ set_flag("has_map")

        play sound "audio/sfx_paper_grab.mp3"  # !!! ЗАМІНИТИ НА РЕАЛЬНИЙ ФАЙЛ !!!

        "Дежавю. Але працює."

    # Повернутись в мол
    scene bg_mall with dissolve
    $ store.current_location = "mall"

    return
