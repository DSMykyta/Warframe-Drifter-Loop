# game/scenes/explore_mall.rpy
# ═══════════════════════════════════════════════════
# СЦЕНА 2: Дрифтер досліджує мол, знаходить карту
# ═══════════════════════════════════════════════════

label explore_mall:

    scene bg_mall with dissolve

    if not is_loop_restart():
        # ═══ ПЕРША ПЕТЛЯ ═══

        "Мол. Великий. Тихий."

        "Музика з динаміків під стелею. Ледь чутно."

        "Вивіски, ескалатори, магазини. Все на місці."

        "Людей — ні."

        "Треба зорієнтуватись."

        scene bg_info_desk with dissolve

        "Інфостійка. Брошури, схеми евакуації."

        "Карта молу. Ціла."

        $ set_flag("has_map")

        "Тир, аркади, медвідділ — периметр. Гараж — через комп-клуб. Дах — сходи з центру."

        "Зрозуміло."

    else:
        # ═══ ПОВТОРНА ПЕТЛЯ ═══

        "Мол. Знову."

        scene bg_info_desk with dissolve

        "Карта на стійці. Там само."

        $ set_flag("has_map")

    # Повернутись в мол
    scene bg_mall with dissolve
    $ store.current_location = "mall"

    return
