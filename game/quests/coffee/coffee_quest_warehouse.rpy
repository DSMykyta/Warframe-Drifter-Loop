# game/quests/coffee/coffee_quest_warehouse.rpy
# ═══════════════════════════════════════════════════
# КВЕСТ КАВИ — ЕТАП 5: Склади. Соло-місія. 4 кінцівки.
# ═══════════════════════════════════════════════════
#
# Кінцівка 1: дістав деталі тихо
# Кінцівка 2: дістав деталі гучно
# Кінцівка 3: не дістав, гучно
# Кінцівка 4: не дістав, 2 стаки травм
#
# Кінцівки 1-2: кав'ярня відкривається наступного дня
# Кінцівки 3-4: Амір знаходить деталі сам через 7 днів + доп опція вибачення

# ═══ ПЕЙДЖЕР ВІД АМІРА (next_day після витягнення) ═══

init python:

    def check_coffee_parts_pager():
        """Перевірити чи час пейджера від Аміра. Викликати в location_loop."""
        if not store.flags.get("coffee_machine_extracted"):
            return
        if store.flags.get("coffee_parts_pager_sent"):
            return
        if not store.flags.get("coffee_parts_mission_pending"):
            return
        if store.minutes < 720:
            return
        pager_send_request(
            "Амір",
            "Марті! Кавомашина майже готова. Потрібні деталі зі складів Скальдри. Підеш?",
            "coffee_parts_pager_yes",
            "coffee_parts_pager_no"
        )
        set_flag("coffee_parts_pager_sent")


label coffee_parts_pager_yes:
    $ set_flag("coffee_parts_mission_available")
    $ generate_missions()
    $ add_pager_message("Амір", "КРАСАВА! Місія на дошці. Іди в гараж.")
    $ add_journal_entry("Амір просить дістати деталі зі складів Скальдри. Місія доступна.", "event")
    return

label coffee_parts_pager_no:
    # Відхилив — кав'ярня відкриється через 7 днів (Амір сам)
    $ set_flag("coffee_parts_declined")
    $ store._coffee_amir_diy_day = store.day + 7
    $ add_pager_message("Амір", "...ну ок. Спробую сам щось придумати.")
    return


# ═══ СПЕЦМІСІЯ: СКЛАДИ СКАЛЬДРИ ═══

init python:
    SPECIAL_MISSION_ENTRIES.append({
        "id": "coffee_parts_mission",
        "name": "Склади Скальдри — деталі",
        "level": 3,
        "conditions": {
            "flag_true": ["coffee_parts_mission_available"],
            "flag_false": ["coffee_parts_mission_done"],
        },
        "chance": 100,
        "partner": None,
        "partner_count": 0,
        "reward": 200,
        "rep": 3,
        "label": "coffee_warehouse_dungeon",
    })


# ═══════════════════════════════════════════════════
# ДАНЖН: СКЛАДИ СКАЛЬДРИ
# ═══════════════════════════════════════════════════

label coffee_warehouse_dungeon:
    # Трекери
    $ _stealth = True       # чи тебе засікли
    $ _found_parts = False   # чи знайшов деталі
    $ _wh_injury = False     # чи отримав травму

    scene bg_warehouse

    "Склади Скальдри. Промзона. Три корпуси за парканом."

    "Потрібні клапан тиску і нагрівальний елемент."

    "Корпус Б, другий поверх."

    # ═══ ВИБІР 1: Підхід ═══

    menu:
        "Головний вхід — швидко, але ризиковано":
            "Паркан низький, ворота напіввідчинені. Зайшов напряму."

            "Камера на стовпі повертається. Повільно."

            menu:
                "Проскочити між поворотами":
                    "Вичекав. Побіг. Встиг."
                    "Всередині. Тихо."

                "Йти спокійно, не ховаючись":
                    "Камера повернулась. Червоний діод мигнув."
                    $ _stealth = False
                    "Десь глибоко в будівлі щось клацнуло. Замок? Сигналізація?"

        "Бічний прохід — через дірку в паркані":
            "Знайшов пролом. Протиснувся."
            "Тихо. Камери сюди не дістають."

        "Через дах — довше, але непомітно":
            "Пожежна драбина. Іржава, але тримає."
            "Дах. Люк. Відкритий."
            "Спустився на другий поверх — саме туди де треба."
            jump coffee_wh_second_floor

    # ═══ ВИБІР 2: Перший поверх — куди ═══

    "Перший поверх. Три коридори."

    "Ліворуч — таблички 'Технічний відділ'. Прямо — сходи нагору. Праворуч — офіси."

    menu:
        "Сходи нагору (другий поверх)":
            "Сходи. Тихо. Другий поверх."
            jump coffee_wh_second_floor

        "Технічний відділ (шукати тут)":
            "Двері відчинені. Всередині — стелажі з деталями."

            "Шукаєш. Клапани, проводка, трубки..."

            menu:
                "Шукати методично, полиця за полицею":
                    "Час. Багато часу. Але знайшов коробку 'Запчастини: кавообладнання'."
                    $ _found_parts = True
                    "Клапан тиску. Нагрівальний елемент. Ущільнювачі. Все тут."

                "Хапати все що схоже":
                    "Набрав купу деталей. Половина не та. Але в мішку щось є..."
                    if renpy.random.randint(1, 100) <= 60:
                        $ _found_parts = True
                        "Пощастило. Клапан і нагрівач — серед купи іншого."
                    else:
                        "Ні. Не ті деталі. Треба на другий поверх."
                        jump coffee_wh_second_floor

            jump coffee_wh_exit

        "Офіси (може є карта складу)":
            "Офіс. Стіл, стілець, папери."
            "Знайшов план будівлі. Корпус Б, другий поверх — 'Побутове обладнання'."
            "Тепер точно знаєш де шукати."
            jump coffee_wh_second_floor


# ═══ ДРУГИЙ ПОВЕРХ ═══

label coffee_wh_second_floor:
    "Другий поверх. Довгий коридор. Двері з обох боків."

    if not _stealth:
        "Десь внизу — кроки. Ти не один."

    "Табличка: 'Побутове обладнання — кімната 2Б-04'."

    menu:
        "Йти до 2Б-04 напряму":
            "Двері. Замок. Звичайний, не електронний."

            menu:
                "Вибити (швидко, гучно)":
                    "Удар плечем. Замок хрусткнув."
                    $ _stealth = False
                    "Гучно. Але всередині."

                "Підібрати (тихо, довго)":
                    "Шпилька. Тиск. Клік."
                    "Відчинено. Тиша."

            "Кімната. Стелажі. Коробки."

            "Третій стелаж, друга полиця: 'Кавообладнання — запасні частини'."

            $ _found_parts = True

            "Клапан тиску. Нагрівальний елемент. Набір ущільнювачів. Все."

        "Перевірити сусідні кімнати спочатку":
            "Кімната 2Б-02 — порожня. Пил."

            "Кімната 2Б-03 — замкнена зсередини."

            menu:
                "Обійти через вентиляцію":
                    "Решітка. Тісно. Але пролазиш."
                    "Кімната 2Б-03 — склад інструментів. Нічого корисного."
                    "Але через стіну — двері в 2Б-04."
                    "Відчинив зсередини. Коробка 'Кавообладнання'. Є."
                    $ _found_parts = True

                "Не ризикувати, йти до 2Б-04":
                    "Назад до 2Б-04. Двері."
                    menu:
                        "Вибити":
                            $ _stealth = False
                            "Гучно. Але деталі знайдені."
                            $ _found_parts = True
                        "Підібрати замок":
                            "Шпилька. Тиск. Клік. Є."
                            $ _found_parts = True

    jump coffee_wh_exit


# ═══ ВИХІД ═══

label coffee_wh_exit:

    if _found_parts:
        "Деталі в рюкзаку. Тепер — вийти."
    else:
        "Порожні руки. Шукати далі чи йти?"

        menu:
            "Ще раз оглянутися":
                "Бігаєш по коридорах. Час спливає."
                "Нічого."
            "Валити звідси":
                pass

    # ═══ ВИБІР 6: ВИХІД ═══

    if _stealth:
        # Тихо — простий вихід

        menu:
            "Тим самим шляхом":
                "Назад. Тихо. Чисто."

            "Через запасний вихід":
                "Пожежні двері. Вулиця. Ніхто не бачив."

    else:
        # Засікли — ускладнення

        "Кроки. Ближче. Хтось йде коридором."

        menu:
            "Сховатись і перечекати":
                "За стелажем. Дихання затримане."
                "Кроки пройшли повз. Тиша."
                "Вийшов через вікно першого поверху."

            "Бігти до виходу":
                "Біжиш. Коридор, сходи, двері."

                if renpy.random.randint(1, 100) <= 40:
                    "Щось летить в голову. Удар. Біль."
                    $ _wh_injury = True
                    "Встаєш. Бік болить. Але вибіг."
                else:
                    "Встиг. Двері за спиною. Вулиця."

            "Відволікти і обійти":
                "Кинув металеву трубу в інший кінець коридору."
                "Гуркіт. Кроки повернули туди."
                "Вийшов через головний. Нікого."

    # ═══════════════════════════════════════════════
    # КІНЦІВКИ
    # ═══════════════════════════════════════════════

    scene black
    pause 0.5

    if _found_parts and _stealth:
        # ═══ КІНЦІВКА 1: Дістав тихо ═══
        "Деталі в рюкзаку. Ніхто не бачив. Чисто."
        $ set_flag("coffee_parts_got")
        $ set_flag("coffee_parts_stealth")
        $ store.money += 200
        $ store.hex_rep += 3
        $ add_chemistry("Амір", 4)
        $ add_journal_entry("Дістав деталі зі складів Скальдри. Тихо, чисто.", "event")

    elif _found_parts and not _stealth:
        # ═══ КІНЦІВКА 2: Дістав гучно ═══
        "Деталі є. Але тебе бачили."
        "Наступного разу буде складніше."
        $ set_flag("coffee_parts_got")
        $ store.money += 200
        $ store.hex_rep += 1  # менше rep за шум
        $ add_chemistry("Амір", 3)
        $ add_journal_entry("Дістав деталі. Але наробив шуму. Скальдра знатиме.", "event")

    elif not _found_parts and not _wh_injury:
        # ═══ КІНЦІВКА 3: Не дістав, без травм ═══
        "Порожні руки. Не знайшов."
        $ set_flag("coffee_parts_failed")
        $ store._coffee_amir_diy_day = store.day + 7
        $ add_journal_entry("Не знайшов деталі. Амір спробує інакше.", "event")

    else:
        # ═══ КІНЦІВКА 4: Не дістав + травми ═══
        "Порожні руки. Бік болить. Голова гуде."
        $ set_flag("coffee_parts_failed")
        $ store._coffee_amir_diy_day = store.day + 7
        $ add_injury_stack("player")
        $ add_injury_stack("player")
        $ add_journal_entry("Провал. Травми. Амір спробує сам.", "event")
        $ add_pager_message("Летті", "Ти поранений. Зайди до мене.")

    $ set_flag("coffee_parts_mission_done")
    $ store.flags["coffee_parts_mission_available"] = False
    $ store.seen_dialogues.add("coffee_parts_mission")

    return


# ═══════════════════════════════════════════════════
# ДОПОВНЕННЯ: вибачення якщо провалив (кінцівки 3-4)
# ═══════════════════════════════════════════════════

init python:
    BONUS_OPTIONS.append({
        "id": "coffee_apology_amir",
        "who": "Амір",
        "text": "Слухай, вибач що не дістав ті деталі...",
        "label": "coffee_apology_amir_scene",
        "conditions": {
            "flag_true": ["coffee_parts_failed"],
            "flag_false": ["coffee_apology_done"],
        },
        "once": True,
    })


label coffee_apology_amir_scene:
    am "Та стій, стій."

    am "Ти пішов. На склади. Один. Заради кавомашини."

    am "Це вже більше ніж треба було."

    mc "Але деталей нема."

    am "Я знайду. Серйозно. Вже маю пару ідей."

    am "Не парся, Марті. Ти зробив більше ніж будь-хто б зробив."

    $ set_flag("coffee_apology_done")
    $ add_chemistry("Амір", 3)

    return


# ═══════════════════════════════════════════════════
# АМІР ЗНАХОДИТЬ ДЕТАЛІ САМ (через 7 днів)
# ═══════════════════════════════════════════════════

init python:

    def check_coffee_amir_diy():
        """Перевірити чи Амір знайшов деталі сам. Викликати в next_day()."""
        if store.flags.get("coffee_parts_got"):
            return
        if not store.flags.get("coffee_parts_failed") and not store.flags.get("coffee_parts_declined"):
            return
        if store.flags.get("coffee_amir_found_parts"):
            return
        target_day = getattr(store, '_coffee_amir_diy_day', 0)
        if store.day >= target_day and target_day > 0:
            set_flag("coffee_amir_found_parts")
            set_flag("coffee_parts_got")
            add_pager_message("Амір", "МАРТІ! Я ЗНАЙШОВ ДЕТАЛІ! Кавомашина буде!!!")
            add_journal_entry("Амір знайшов деталі для кавомашини сам.", "event")
