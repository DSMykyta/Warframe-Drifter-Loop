# game/quests/coffee/coffee_quest_milk.rpy
# ═══════════════════════════════════════════════════
# КВЕСТ КАВИ — ЕТАП 8: Місія на молоко
# ═══════════════════════════════════════════════════
#
# Результат залежить від виборів на місії:
#   - Сухе молоко: розблоковує лате, какао (слабші версії)
#   - Свіже молоко: розблоковує лате, какао, капучіно (найкращі)
#   - Пастеризоване: розблоковує лате, какао (середні)
#
# Можна знайти тільки один тип за місію.

init python:
    SPECIAL_MISSION_ENTRIES.append({
        "id": "coffee_milk_mission",
        "name": "Пошук молока",
        "level": 2,
        "conditions": {
            "flag_true": ["milk_quest_started"],
            "flag_false": ["milk_mission_done"],
        },
        "chance": 100,
        "partner": None,
        "partner_count": 0,
        "reward": 100,
        "rep": 2,
        "label": "coffee_milk_scene",
    })


label coffee_milk_scene:
    scene bg_warehouse

    "Склад поруч з консервами. Аоі казала — сухе молоко має бути тут."

    "Стелажі. Коробки. Пил."

    "Перший ряд — консерви. Другий — сухі суміші. Третій..."

    "Третій ряд. Картонна коробка з написом: 'СУХЕ МОЛОКО — 24 шт.'"

    "Дві пачки всередині. Решта порожня. Але це щось."

    $ _milk_type = "dry"  # За замовчуванням — сухе

    menu:
        "Взяти сухе і йти":
            "Дві пачки сухого молока в рюкзак. Достатньо."
            $ _milk_type = "dry"

        "Пошукати ще":
            "Далі. Сусідній стелаж."

            "Холодильник. Старий, промисловий. Не працює."

            "Відкриваєш."

            "Всередині — пластикові пляшки. 'Пастеризоване молоко — зберігати при +4°C'."

            "Холодильник мертвий давно. Але пляшки запечатані."

            menu:
                "Взяти пастеризоване (запечатане, можливо ще добре)":
                    "Три пляшки. Запечатані. Може пощастить."
                    $ _milk_type = "pasteurized"

                "Не ризикувати, залишити сухе":
                    "Сухе надійніше. Не зіпсується."
                    $ _milk_type = "dry"

                "Шукати далі":
                    "Далі. За стелажами — двері. 'Персонал'."

                    "Відчинено. Маленька кімната. Холодильник — менший. Гуде."

                    "Цей працює. Генератор десь тарахтить."

                    "Відкриваєш. Свіже молоко. Справжнє. Пляшки з датою... три дні тому."

                    "Ще добре."

                    menu:
                        "Взяти свіже (найкраще, але швидко зіпсується)":
                            "Дві пляшки свіжого. Треба донести швидко."
                            $ _milk_type = "fresh"

                        "Занадто ризиковано. Взяти пастеризоване.":
                            $ _milk_type = "pasteurized"

                        "Взяти все — і сухе, і свіже":
                            "Рюкзак повний. Сухе і свіже. Подвійний улов."
                            $ _milk_type = "fresh"
                            $ set_flag("also_got_dry_milk")

    scene black
    pause 0.5

    # ═══ РЕЗУЛЬТАТ ═══

    if _milk_type == "fresh":
        "Свіже молоко доставлене. Амір буде в екстазі."
        $ set_flag("milk_type_fresh")
        $ set_flag("milk_drinks_unlocked")
        $ set_flag("milk_cappuccino_unlocked")
        $ add_pager_message("Амір", "СВІЖЕ?! СПРАВЖНЄ СВІЖЕ МОЛОКО?! Я ТЕБЕ ОБОЖНЮЮ")
        $ add_chemistry("Амір", 4)
        $ add_journal_entry("Знайшов свіже молоко. Лате, какао, капучіно — розблоковано.", "event")

    elif _milk_type == "pasteurized":
        "Пастеризоване молоко доставлене. Непогано."
        $ set_flag("milk_type_pasteurized")
        $ set_flag("milk_drinks_unlocked")
        $ add_pager_message("Амір", "Пастеризоване! Не ідеал, але ПРАЦЮЄ!")
        $ add_chemistry("Амір", 3)
        $ add_journal_entry("Знайшов пастеризоване молоко. Лате і какао — розблоковано.", "event")

    elif _milk_type == "dry":
        "Сухе молоко доставлене. Краще ніж нічого."
        $ set_flag("milk_type_dry")
        $ set_flag("milk_drinks_unlocked")
        $ add_pager_message("Амір", "Сухе... ну... краще ніж нічого! Лате буде!")
        $ add_chemistry("Амір", 2)
        $ add_journal_entry("Знайшов сухе молоко. Лате і какао — розблоковано (базові).", "event")

    $ set_flag("milk_mission_done")
    $ store.seen_dialogues.add("coffee_milk_mission")
    $ store.money += 100
    $ store.hex_rep += 2

    return
